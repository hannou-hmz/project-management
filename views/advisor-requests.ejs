<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Advisor Requests</title>
    <link rel="stylesheet" href="/advisor-styling/advisor-requests.css">
    <link rel="icon" href="/img/fav.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <a class="nav-logo" href="/advisor/dashboard">Team<span>Match</span></a>
        <div class="nav-links">
            <a href="/advisor/dashboard" class="nav-link">Dashboard</a>
            <a href="/advisor/projects" class="nav-link">My Projects</a>
            <a href="/advisor/requests" class="nav-link active">Requests</a>
        </div>
        <div class="nav-actions">
            <a href="/advisor/profile" class="nav-btn-outline">Profile</a>
            <a href="/logout" class="nav-btn-logout">Logout</a>
        </div>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-eyebrow">Advisor Portal</div>
            <h1 class="page-title">Student Requests</h1>
            <p class="page-sub">Review advising requests from students and respond to each one.</p>
        </div>
    </div>

    <div class="container">

        <% if (requests && requests.length > 0) { %>

            <%
                const total    = requests.length;
                const accepted = requests.filter(r => (r.status||'pending').toLowerCase() === 'accepted').length;
                const rejected = requests.filter(r => (r.status||'pending').toLowerCase() === 'rejected').length;
                const pending  = total - accepted - rejected;
            %>

            <!-- Summary bar -->
            <div class="summary-bar">
                <div class="summary-stat">
                    <span class="summary-num"><%= total %></span>
                    <span class="summary-label">Total</span>
                </div>
                <div class="summary-divider"></div>
                <div class="summary-stat">
                    <span class="summary-num pending-num"><%= pending %></span>
                    <span class="summary-label">Pending</span>
                </div>
                <div class="summary-divider"></div>
                <div class="summary-stat">
                    <span class="summary-num accepted-num"><%= accepted %></span>
                    <span class="summary-label">Accepted</span>
                </div>
                <div class="summary-divider"></div>
                <div class="summary-stat">
                    <span class="summary-num rejected-num"><%= rejected %></span>
                    <span class="summary-label">Rejected</span>
                </div>
            </div>

            <!-- Requests list -->
            <div class="requests-list">

                <% requests.forEach(request => { %>
                <%
                    const s = (request.status || 'pending').toLowerCase();
                    const cardClass = s === 'accepted' ? 'card-accepted'
                                    : s === 'rejected' ? 'card-rejected'
                                    : 'card-pending';
                %>
                <div class="req-card <%= cardClass %>">

                    <!-- Status ribbon -->
                    <div class="status-ribbon ribbon-<%= s %>">
                        <% if (s === 'accepted') { %>
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            Accepted
                        <% } else if (s === 'rejected') { %>
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            Rejected
                        <% } else { %>
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            Pending review
                        <% } %>
                    </div>

                    <div class="req-body">

                        <!-- Student header -->
                        <div class="student-header">
                            <div class="student-avatar avatar-<%= s %>">
                                <%= request.full_name ? request.full_name.charAt(0).toUpperCase() : 'S' %>
                            </div>
                            <div class="student-info">
                                <div class="student-name"><%= request.full_name %></div>
                                <div class="student-sub-row">
                                    <span class="student-meta">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                        <%= request.email %>
                                    </span>
                                    <span class="dot-sep">·</span>
                                    <span class="student-meta">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                        <%= request.department_name %>
                                    </span>
                                </div>
                            </div>
                            <div class="req-date">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                <%= new Date(request.requested_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                            </div>
                        </div>

                        <div class="req-divider"></div>

                        <!-- Project info -->
                        <div class="project-block">
                            <div class="project-block-header">
                                <h3 class="project-title"><%= request.project_title %></h3>
                                <div class="project-badges">
                                    <span class="badge category-badge"><%= request.category_name %></span>
                                    <span class="badge meeting-badge">
                                        <% if (request.meeting_method === 'online') { %>
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                                            Online
                                        <% } else { %>
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                            In Person
                                        <% } %>
                                    </span>
                                </div>
                            </div>
                            <p class="project-desc"><%= request.project_description %></p>
                        </div>

                        <!-- Student message -->
                        <% if (request.request_message) { %>
                        <div class="message-block">
                            <div class="message-label">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                Message from student
                            </div>
                            <p class="message-text"><%= request.request_message %></p>
                        </div>
                        <% } %>

                        <!-- Actions -->
                        <div class="req-actions">
                            <% if (s === 'pending') { %>

                                <form action="/advisor/requests/<%= request.request_id %>/accept" method="GET" style="display:contents;">
                                    <button type="submit" class="btn-accept">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                        Accept Request
                                    </button>
                                </form>

                                <form action="/advisor/requests/<%= request.request_id %>/reject" method="GET" style="display:contents;">
                                    <button type="submit" class="btn-reject">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                        Decline
                                    </button>
                                </form>

                            <% } else if (s === 'accepted') { %>

                                <div class="decision-label accepted-label">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    You accepted this advising request
                                </div>
                                <form action="/advisor/requests/<%= request.request_id %>/reject" method="GET" style="display:contents;">
                                    <button type="submit" class="btn-undo">Undo decision</button>
                                </form>

                            <% } else { %>

                                <div class="decision-label rejected-label">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    You declined this request
                                </div>
                                <form action="/advisor/requests/<%= request.request_id %>/accept" method="GET" style="display:contents;">
                                    <button type="submit" class="btn-undo">Undo decision</button>
                                </form>

                            <% } %>
                        </div>

                    </div>
                </div>
                <% }) %>

            </div>

        <% } else { %>

            <div class="empty-state">
                <div class="empty-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div class="empty-title">No requests yet</div>
                <p class="empty-sub">No students have sent you an advising request yet. Make sure your profile is set to available.</p>
                <a href="/advisor/profile" class="btn-primary">Check your availability</a>
            </div>

        <% } %>

    </div>

    <footer class="footer">
        <div class="footer-inner">
            <span class="footer-logo">Team<span>Match</span></span>
            <span class="footer-copy">University Project Collaboration Platform</span>
        </div>
    </footer>

</body>
</html>
