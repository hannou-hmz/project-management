<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Requests — Advisor · TeamMatch</title>
<link rel="stylesheet" href="/advisor-styling/advisor-requests.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<%
const isAvailable = !!(advisor && (advisor.is_available || advisor.available));
%>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ═══════════════════════════════════════
    SIDEBAR
════════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">

<div class="sb-brand">
<div class="sb-logo">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor"/><path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/><path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
</div>
<div class="sb-brand-text">
    <a href="/advisor/dashboard" class="sb-name">Team<em>Match</em></a>
    <span class="sb-role">Advisor Portal</span>
</div>
</div>

<% if (typeof advisor !== 'undefined' && advisor) { %>
<div class="sb-profile" onclick="window.location.href='/advisor/profile'" title="View profile">
<div class="sp-avatar">
    <%= advisor.full_name ? advisor.full_name.split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase() : 'AD' %>
</div>
<div class="sp-info">
    <div class="sp-name"><%= advisor.full_name || 'Advisor' %></div>
    <% if (advisor.academic_title) { %>
    <div class="sp-title"><%= advisor.academic_title %></div>
    <% } %>
</div>
<div class="sp-avail-dot <%= isAvailable ? 'dot-on' : 'dot-off' %>"></div>
</div>

<div class="sb-avail-strip <%= isAvailable ? 'avail-on' : 'avail-off' %>">
<span class="sa-label"><%= isAvailable ? 'Available for advising' : 'Not accepting requests' %></span>
<a href="/advisor/profile" class="sa-link">Change →</a>
</div>
<% } %>

<div class="sb-divider"></div>

<nav class="sb-nav">
<div class="sb-nav-label">Navigation</div>

<a href="/advisor/dashboard" class="sb-link">
    <span class="sb-link-icon">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
    </span>
    <span class="sb-link-label">Dashboard</span>
</a>

<a href="/advisor/projects" class="sb-link">
    <span class="sb-link-icon">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/></svg>
    </span>
    <span class="sb-link-label">My Projects</span>
</a>

<a href="/advisor/requests" class="sb-link active">
    <span class="sb-link-icon">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </span>
    <span class="sb-link-label">Student Requests</span>
</a>

<a href="/advisor/profile" class="sb-link">
    <span class="sb-link-icon">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </span>
    <span class="sb-link-label">My Profile</span>
</a>
</nav>

<div class="sb-footer">
<a href="/logout" class="sb-logout-btn">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    Logout
</a>
</div>

</aside>

<!-- ═══════════════════════════════════════
    LAYOUT MAIN
════════════════════════════════════════ -->
<div class="layout-main">

<!-- ── Topbar ── -->
<header class="topbar">
<div class="topbar-left">
    <button class="mobile-toggle" onclick="toggleSidebar()" aria-label="Toggle sidebar">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="topbar-breadcrumb">
    <span class="tb-root">TeamMatch</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="tb-current">Student Requests</span>
    </div>
</div>
<div class="topbar-right">
    <% if (requests && requests.length > 0) { %>
    <div class="topbar-count">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <strong><%= requests.length %></strong>&nbsp;request<%= requests.length !== 1 ? 's' : '' %>
    </div>
    <% } %>
</div>
</header>

<!-- ── Page content ── -->
<main class="page-content">

<div class="page-heading">
    <div>
    <h1 class="page-title">Student Requests</h1>
    <p class="page-subtitle">Review advising requests from students and respond to each one.</p>
    </div>
</div>

<% if (requests && requests.length > 0) { %>

<%
    const total    = requests.length;
    const accepted = requests.filter(r => (r.status||'pending').toLowerCase() === 'accepted').length;
    const rejected = requests.filter(r => (r.status||'pending').toLowerCase() === 'rejected').length;
    const pending  = total - accepted - rejected;
%>

<!-- Summary strip -->
<div class="summary-strip">
    <div class="summary-stat">
    <div class="ss-num"><%= total %></div>
    <div class="ss-label">Total</div>
    </div>
    <div class="ss-sep"></div>
    <div class="summary-stat">
    <div class="ss-num ss-amber"><%= pending %></div>
    <div class="ss-label">Pending</div>
    </div>
    <div class="ss-sep"></div>
    <div class="summary-stat">
    <div class="ss-num ss-green"><%= accepted %></div>
    <div class="ss-label">Accepted</div>
    </div>
    <div class="ss-sep"></div>
    <div class="summary-stat">
    <div class="ss-num ss-coral"><%= rejected %></div>
    <div class="ss-label">Rejected</div>
    </div>
</div>

<!-- Requests -->
<div class="requests-list">

    <% requests.forEach(request => { %>
    <%
    const s = (request.status || 'pending').toLowerCase();
    const cardClass = s === 'accepted' ? 'rc-accepted'
                    : s === 'rejected' ? 'rc-rejected'
                    : 'rc-pending';
    %>
    <div class="req-card <%= cardClass %>">

    <!-- Status ribbon -->
    <div class="status-ribbon ribbon-<%= s %>">
        <% if (s === 'accepted') { %>
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Accepted
        <% } else if (s === 'rejected') { %>
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        Rejected
        <% } else { %>
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Pending review
        <% } %>
    </div>

    <div class="req-body">

        <!-- Student header -->
        <div class="student-header">
        <div class="student-avatar avatar-<%= s %>">
            <%= request.full_name ? request.full_name.charAt(0).toUpperCase() : 'S' %>
        </div>
        <div class="student-info">
            <div class="student-name"><%= request.full_name %></div>
            <div class="student-sub-row">
            <span class="student-meta">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <%= request.email %>
            </span>
            <span class="dot-sep">·</span>
            <span class="student-meta">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <%= request.department_name %>
            </span>
            </div>
        </div>
        <div class="req-date">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <%= new Date(request.requested_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
        </div>
        </div>

        <div class="req-divider"></div>

        <!-- Project info -->
        <div class="project-block">
        <div class="project-block-header">
            <h3 class="project-title"><%= request.project_title %></h3>
            <div class="project-badges">
            <span class="badge badge-cat"><%= request.category_name %></span>
            <span class="badge badge-meeting">
                <% if (request.meeting_method === 'online') { %>
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                Online
                <% } else { %>
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                In Person
                <% } %>
            </span>
            </div>
        </div>
        <p class="project-desc"><%= request.project_description %></p>
        </div>

        <!-- Student message -->
        <% if (request.request_message) { %>
        <div class="message-block">
        <div class="message-label">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Message from student
        </div>
        <p class="message-text"><%= request.request_message %></p>
        </div>
        <% } %>

        <!-- Actions -->
        <div class="req-actions">
        <% if (s === 'pending') { %>

            <form action="/advisor/requests/<%= request.request_id %>/accept?_method=PATCH" method="POST" style="display:contents;">
            <button type="submit" class="btn-accept">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Accept Request
            </button>
            </form>

            <form action="/advisor/requests/<%= request.request_id %>/reject?_method=PATCH" method="POST" style="display:contents;">
            <button type="submit" class="btn-reject">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Decline
            </button>
            </form>

        <% } else if (s === 'accepted') { %>

            <div class="decision-label decision-accepted">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            You accepted this advising request
            </div>
            <form action="/advisor/requests/<%= request.request_id %>/reject?_method=PATCH" method="POST" style="display:contents;">
            <button type="submit" class="btn-undo">Undo decision</button>
            </form>

        <% } else { %>

            <div class="decision-label decision-rejected">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            You declined this request
            </div>
            <form action="/advisor/requests/<%= request.request_id %>/accept?_method=PATCH" method="POST" style="display:contents;">
            <button type="submit" class="btn-undo">Undo decision</button>
            </form>

        <% } %>
        </div>

    </div>
    </div>
    <% }) %>

</div>

<% } else { %>

<div class="panel">
    <div class="empty-state">
    <div class="empty-icon-wrap">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </div>
    <div class="empty-title">No requests yet</div>
    <p class="empty-sub">No students have sent you an advising request yet. Make sure your profile is set to available.</p>
    <a href="/advisor/profile" class="btn-primary">Check your availability</a>
    </div>
</div>

<% } %>

</main>
</div>

<script>
function toggleSidebar() {
document.getElementById('sidebar').classList.toggle('open');
document.getElementById('sidebarOverlay').classList.toggle('visible');
}
function closeSidebar() {
document.getElementById('sidebar').classList.remove('open');
document.getElementById('sidebarOverlay').classList.remove('visible');
}

document.addEventListener('DOMContentLoaded', () => {
document.querySelectorAll('.req-card').forEach((card, i) => {
    card.style.opacity = '0';
    card.style.transform = 'translateY(12px)';
    setTimeout(() => {
    card.style.transition = 'opacity .4s ease, transform .4s ease';
    card.style.opacity = '1';
    card.style.transform = 'translateY(0)';
    }, 60 + i * 55);
});
});
</script>

</body>
</html>
