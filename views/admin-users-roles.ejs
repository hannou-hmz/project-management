<h1>Users</h1>

<% if (users && users.length > 0) { %>

    <% users.forEach(user => { %>

        <div style="margin-bottom: 20px;">

            <h3><strong>Full Name:</strong> <%= user.full_name %></h3>

            <p><strong>Email:</strong> <%= user.email %></p>

            <p><strong>Department:</strong> <%= user.department_name %></p>

            <p><strong>Role:</strong> <%= user.role_name %></p> 

            <a style="background-color: rgb(94, 94, 94);color: white; padding: 7px;" 
            href="/admin/users/<%= user.user_id%>/delete">Delete user</a>

           
            <form action="/admin/<%= user.user_id %>/change-role?_method=PATCH" method="POST">
                <select name="roleId" required>
                    <option value="">-- Select a category --</option>

                    <% roles.forEach(role => { %>
                        <option value="<%= role.role_id %>">
                            <%= role.role_name %>
                        </option>
                    <% }) %>

                </select>

                <button type="submit">Change Role</button>
            </form>
            

        </div>

        <hr>

    <% }) %>

<% } else { %>

    <p>No users found.</p>

<% } %>