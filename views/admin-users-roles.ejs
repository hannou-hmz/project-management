<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Users & Roles — Admin</title>
<link rel="stylesheet" href="/admin-styling/admin-users-roles.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
</head>
<body>

<!-- ===== SIDEBAR OVERLAY ===== -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ===== SIDEBAR ===== -->
<aside class="sidebar" id="sidebar">

  <div class="sb-brand">
    <div class="sb-logo">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </div>
    <div class="sb-brand-text">
      <span class="sb-name">Team<em>Match</em></span>
      <span class="sb-role">Admin Panel</span>
    </div>
  </div>

  <nav class="sb-nav">
    <div class="sb-nav-label">Navigation</div>

    <a href="/admin/homepage" class="sb-link">
      <span class="sb-link-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      </span>
      <span class="sb-link-label">Dashboard</span>
    </a>

    <a href="/admin/categories" class="sb-link">
      <span class="sb-link-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      </span>
      <span class="sb-link-label">Categories</span>
    </a>

    <a href="/admin/projects" class="sb-link">
      <span class="sb-link-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      </span>
      <span class="sb-link-label">Projects</span>
    </a>

    <a href="/admin/announcements" class="sb-link">
      <span class="sb-link-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      </span>
      <span class="sb-link-label">Announcements</span>
    </a>

    <a href="/admin/users/roles" class="sb-link active">
      <span class="sb-link-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </span>
      <span class="sb-link-label">Users & Roles</span>
    </a>

  </nav>

  <div class="sb-footer">
    <div class="sb-admin-row">
      <div class="sb-avatar">A</div>
      <div class="sb-admin-info">
        <div class="sb-admin-name">Administrator</div>
        <div class="sb-admin-sub">Super Admin</div>
      </div>
      <a href="/logout" class="sb-logout-btn" title="Logout">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    </div>
  </div>

</aside>

<!-- ===== LAYOUT MAIN ===== -->
<div class="layout-main">

  <!-- TOPBAR -->
  <div class="topbar anim-topbar">
    <div class="topbar-left">
      <button class="mobile-toggle" id="mobileToggle" onclick="openSidebar()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-breadcrumb">
        <span class="tb-root">Admin</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="tb-current">Users & Roles</span>
      </div>
    </div>
    <div class="topbar-right">
      <% if (users && users.length > 0) { %>
      <div class="topbar-count-pill">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <strong><%= users.length %></strong>&nbsp;user<%= users.length !== 1 ? 's' : '' %>
      </div>
      <% } %>
      <div class="tb-sep"></div>
      <div class="topbar-status">
        <span class="status-dot"></span>
        <span>System Online</span>
      </div>
    </div>
  </div>

  <!-- PAGE CONTENT -->
  <div class="page-content">

    <!-- Page Heading -->
    <div class="page-heading anim-heading">
      <div>
        <h1 class="page-title">Users & Roles</h1>
        <p class="page-subtitle">Manage user accounts, assign roles, and control platform access</p>
      </div>
    </div>

    <% if (users && users.length > 0) { %>

    <!-- Search Toolbar -->
    <div class="panel anim-toolbar">
      <div class="toolbar-inner">
        <div class="search-wrap">
          <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" class="search-input" id="searchInput" placeholder="Search by name, email, or department…">
        </div>
        <div class="toolbar-meta">
          <span id="visibleCount"><%= users.length %></span> of <span><%= users.length %></span> users
        </div>
      </div>
    </div>

    <!-- Users Table Panel -->
    <div class="panel anim-panel">
      <div class="panel-header">
        <div class="panel-header-left">
          <div class="panel-title">All Users</div>
          <div class="panel-sub">Manage accounts and assign roles below</div>
        </div>
      </div>

      <div class="panel-body">
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Department</th>
                <th>Current Role</th>
                <th>Change Role</th>
                <th style="text-align:right;">Action</th>
              </tr>
            </thead>
            <tbody id="usersTableBody">

              <% users.forEach((user, index) => { %>
              <tr class="table-row table-row-anim"
                  style="--row-index: <%= index %>;"
                  data-name="<%= user.full_name %>"
                  data-email="<%= user.email %>"
                  data-dept="<%= user.department_name %>">

                <!-- User -->
                <td>
                  <div class="user-cell">
                    <div class="user-avatar">
                      <%= user.full_name ? user.full_name.charAt(0).toUpperCase() : '?' %>
                    </div>
                    <div class="user-info">
                      <div class="user-name"><%= user.full_name %></div>
                      <div class="user-email"><%= user.email %></div>
                    </div>
                  </div>
                </td>

                <!-- Department -->
                <td>
                  <span class="dept-tag"><%= user.department_name %></span>
                </td>

                <!-- Current Role Badge -->
                <td>
                  <%
                    let roleClass = 'role-default';
                    const rn = (user.role_name || '').toLowerCase();
                    if (rn === 'admin')      roleClass = 'role-admin';
                    else if (rn === 'instructor' || rn === 'advisor') roleClass = 'role-advisor';
                    else if (rn === 'student') roleClass = 'role-student';
                  %>
                  <span class="badge <%= roleClass %>"><%= user.role_name %></span>
                </td>

                <!-- Change Role Form -->
                <td>
                  <form action="/admin/<%= user.user_id %>/change-role?_method=PATCH" method="POST" class="role-form">
                    <select name="roleId" required class="role-select">
                      <option value="">— Select role —</option>
                      <% roles.forEach(role => { %>
                        <option value="<%= role.role_id %>"><%= role.role_name %></option>
                      <% }) %>
                    </select>
                    <button type="submit" class="btn btn-secondary btn-sm">Apply</button>
                  </form>
                </td>

                <!-- Delete -->
                <td style="text-align:right;">
                  <button class="btn btn-danger btn-sm"
                          data-name="<%= user.full_name %>"
                          data-id="<%= user.user_id %>"
                          onclick="openDeleteModal(this)">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    Delete
                  </button>
                </td>

              </tr>
              <% }) %>

            </tbody>
          </table>
        </div>

        <!-- Empty search state -->
        <div class="empty-search" id="emptySearch" style="display:none;">
          <div class="empty-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <div class="empty-title">No users match your search</div>
          <p class="empty-sub">Try adjusting your search terms.</p>
        </div>

      </div>
    </div>

    <% } else { %>

    <!-- Empty State -->
    <div class="panel empty-state-panel anim-panel">
      <div class="empty-state">
        <div class="empty-icon-wrap">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="empty-title">No users found</div>
        <p class="empty-sub">No users are registered on the platform yet.</p>
      </div>
    </div>

    <% } %>

  </div><!-- /page-content -->
</div><!-- /layout-main -->


<!-- ===== DELETE MODAL ===== -->
<div class="modal-backdrop" id="modalBackdrop" onclick="closeDeleteModal()">
  <div class="modal" onclick="event.stopPropagation()">

    <div class="modal-icon-del">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
    </div>

    <h3 class="modal-title">Delete User</h3>
    <p class="modal-body-text">
      Are you sure you want to permanently delete
      <strong id="deleteUserName"></strong>?
      Their projects, applications, and requests will also be removed.
    </p>

    <form id="deleteForm" action="" method="POST">
      <input type="hidden" name="_method" value="DELETE">
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" onclick="closeDeleteModal()">Cancel</button>
        <button type="submit" class="btn btn-danger">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
          Delete User
        </button>
      </div>
    </form>

  </div>
</div>


<script>
  // ===== SIDEBAR MOBILE =====
  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    const ov = document.getElementById('sidebarOverlay');
    ov.style.display = 'block';
    requestAnimationFrame(() => ov.classList.add('visible'));
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    const ov = document.getElementById('sidebarOverlay');
    ov.classList.remove('visible');
    setTimeout(() => { ov.style.display = 'none'; }, 250);
    document.body.style.overflow = '';
  }

  // ===== DELETE MODAL =====
  function openDeleteModal(btn) {
    document.getElementById('deleteUserName').textContent = btn.dataset.name;
    document.getElementById('deleteForm').setAttribute(
      'action',
      '/admin/users/' + btn.dataset.id + '/delete?_method=DELETE'
    );
    document.getElementById('modalBackdrop').classList.add('visible');
    document.body.style.overflow = 'hidden';
  }
  function closeDeleteModal() {
    document.getElementById('modalBackdrop').classList.remove('visible');
    document.body.style.overflow = '';
  }

  // ===== SEARCH =====
  const searchInput  = document.getElementById('searchInput');
  const rows         = document.querySelectorAll('.table-row');
  const emptySearch  = document.getElementById('emptySearch');
  const visibleCount = document.getElementById('visibleCount');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase();
      let visible = 0;
      rows.forEach(row => {
        const name  = (row.dataset.name  || '').toLowerCase();
        const email = (row.dataset.email || '').toLowerCase();
        const dept  = (row.dataset.dept  || '').toLowerCase();
        const match = !q || name.includes(q) || email.includes(q) || dept.includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (emptySearch) emptySearch.style.display = visible === 0 ? 'flex' : 'none';
      if (visibleCount) visibleCount.textContent = visible;
    });
  }

  // ===== ENTRANCE ANIMATIONS =====
  document.addEventListener('DOMContentLoaded', () => {
    requestAnimationFrame(() => {
      document.querySelectorAll('.anim-topbar, .anim-heading, .anim-toolbar, .anim-panel')
        .forEach(el => el.classList.add('is-visible'));
    });

    // Stagger table rows (driven by --row-index CSS custom property)
    document.querySelectorAll('.table-row-anim').forEach(row => {
      row.classList.add('row-visible');
    });
  });

  // Close on Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeDeleteModal();
  });
</script>

</body>
</html>
