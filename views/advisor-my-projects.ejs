<h1>My Projects</h1>

<% if (projects && projects.length > 0) { %>

    <% projects.forEach(p => { %>

        <div style="border: 1px solid #ccc; padding: 15px; margin-bottom: 20px; border-radius: 10px;">

            <h3><%= p.project_title %></h3>

            <p><strong>Student Name:</strong> <%= p.full_name %></p>
            <p><strong>Email:</strong> <%= p.email %></p>

            <hr>

            <p><strong>Project Description:</strong></p>
            <p><%= p.project_description %></p>

            <p><strong>Budget:</strong> $<%= p.budget %></p>

            <p><strong>Meeting Method:</strong> 
                <%= p.meeting_method === "online" ? "Online 💻" : "In Person 🏫" %>
            </p>

        </div>

    <% }) %>

<% } else { %>

    <p>No projects assigned yet.</p>

<% } %>