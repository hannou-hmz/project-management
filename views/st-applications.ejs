<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Applications</title>
    <link rel="stylesheet" href="/styling/applications.css">
    <link rel="icon" href="/img/fav.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styling/st-applications.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <a class="nav-logo" href="/student/homepage">Team<span>Match</span></a>
        <div class="nav-links">
            <a href="/student/projects" class="nav-link">Browse Projects</a>
            <a href="/student/myprojects" class="nav-link">My Projects</a>
            <a href="/student/applications" class="nav-link active">Applications</a>
            <a href="/student/find/advisors" class="nav-link">Find Advisor</a>
        </div>
        <div class="nav-actions">
            <a href="/student/create/projects" class="nav-btn-accent">+ Create Project</a>
            <a href="/student/profile" class="nav-btn-outline">Profile</a>
            <a href="/logout" class="nav-btn-logout">Logout</a>
        </div>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-eyebrow">Student Portal</div>
            <h1 class="page-title">My Applications</h1>
            <p class="page-sub">Track the projects you've applied to join.</p>
        </div>
    </div>

    <div class="container">

        <% if (applications && applications.length > 0) { %>

            <!-- Toolbar -->
            <div class="toolbar">
                <span class="results-count">
                    <strong><%= applications.length %></strong> application<%= applications.length !== 1 ? 's' : '' %>
                </span>
                <a href="/student/projects" class="btn-outline">Browse more projects →</a>
            </div>

            <!-- Applications List -->
            <div class="apps-list">

                <% applications.forEach(app => { %>
                <div class="app-card">

                    <div class="app-body">

                        <!-- Header -->
                        <div class="app-header">
                            <div class="app-header-left">
                                <h3 class="app-title"><%= app.project_title %></h3>
                                <div class="app-badges">
                                    <span class="badge badge-category"><%= app.category_name %></span>
                                    <span class="badge badge-date">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                        Applied <%= new Date(app.request_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                    </span>
                                </div>
                            </div>
                            <a class="delete-btn"
                               href="/student/applications/<%= app.request_id %>/delete"
                               onclick="return confirm('Withdraw this application?')">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                Withdraw
                            </a>
                        </div>

                        <!-- Message -->
                        <% if (app.request_message) { %>
                        <div class="app-message-wrap">
                            <div class="app-message-label">Your message</div>
                            <p class="app-message"><%= app.request_message %></p>
                        </div>
                        <% } %>
                        
                    </div>

                </div>
                <% }) %>

            </div>

        <% } else { %>

            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-icon">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                </div>
                <div class="empty-title">No applications yet</div>
                <p class="empty-sub">You haven't applied to any projects. Browse open projects and find your next collaboration.</p>
                <a href="/student/projects" class="btn-primary">Browse Projects →</a>
            </div>

        <% } %>

    </div>

    <footer class="footer">
        <div class="footer-inner">
            <span class="footer-logo">Team<span>Match</span></span>
            <span class="footer-copy">University Project Collaboration Platform</span>
        </div>
    </footer>

</body>
</html>
