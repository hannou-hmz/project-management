<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Projects</title>
    <link rel="stylesheet" href="/styling/st-my-projects.css">
    <link rel="icon" href="/img/fav.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <a class="nav-logo" href="/student/homepage">Team<span>Match</span></a>
        <div class="nav-links">
            <a href="/student/projects" class="nav-link">Browse Projects</a>
            <a href="/student/myprojects" class="nav-link">My Projects</a>
            <a href="/student/applications" class="nav-link">Applications</a>
            <a href="/student/announcements" class="nav-link">Announcements</a>
            <a href="/student/find/advisors" class="nav-link">Find Advisor</a>
            <a href="/student/requests" class="nav-link">Requests</a>
            <a href="/student/applicants" class="nav-link">Applicants</a>
        </div>
        <div class="nav-actions">
            <a href="/student/create/projects" class="nav-btn-accent">+ Create Project</a>
            <a href="/student/profile" class="nav-btn-outline">Profile</a>
            <a href="/logout" class="nav-btn-logout">Logout</a>
        </div>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-eyebrow">Student Portal</div>
            <h1 class="page-title">My Projects</h1>
            <p class="page-sub">Projects you've created and are currently managing.</p>
        </div>
    </div>

    <div class="container">

        <% if (projects && projects.length > 0) { %>

            <!-- Toolbar -->
            <div class="toolbar">
                <span class="results-count">
                    <strong><%= projects.length %></strong> project<%= projects.length !== 1 ? 's' : '' %>
                </span>
                <a href="/student/create/projects" class="btn-primary">+ Create New Project</a>
            </div>

            <!-- Projects List -->
            <div class="projects-list">

                <% projects.forEach(project => { %>
                <div class="project-card">

                    <div class="pc-body">

                        <!-- Header row -->
                        <div class="pc-header">
                            <div class="pc-header-left">
                                <h3 class="pc-title"><%= project.project_title %></h3>
                                <div class="pc-badges">
                                    <span class="badge badge-category"><%= project.category_name %></span>
                                    <span class="badge <%= project.require_advisor ? 'badge-advisor' : 'badge-no-advisor' %>">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                        Advisor: <%= project.require_advisor ? "Required" : "Not required" %>
                                    </span>
                                </div>
                            </div>

                            <!-- Delete button — triggers custom modal -->
                            <button class="delete-btn"
                                    data-href="/student/<%= project.project_id %>/delete"
                                    data-title="<%= project.project_title %>"
                                    onclick="openDeleteModal(this)">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                Delete
                            </button>
                        </div>

                        <!-- Description -->
                        <p class="pc-desc"><%= project.project_description %></p>

                        <!-- Skills tags -->
                        <% if (project.required_skills) { %>
                        <div class="pc-tags">
                            <% project.required_skills.split(',').forEach(skill => { %>
                                <span class="pc-tag"><%= skill.trim() %></span>
                            <% }) %>
                        </div>
                        <% } %>

                        <!-- Meta grid -->
                        <div class="pc-meta-grid">
                            <div class="meta-item">
                                <div class="meta-label">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                                    Budget
                                </div>
                                <div class="meta-value"><%= project.budget ? Number(project.budget).toLocaleString() + ' USD' : 'N/A' %></div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                    Team Size
                                </div>
                                <div class="meta-value"><%= project.team_size %> members</div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    Created
                                </div>
                                <div class="meta-value"><%= new Date(project.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                            </div>
                        </div>

                    </div>
                </div>
                <% }) %>

            </div>

        <% } else { %>

            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-icon">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                </div>
                <div class="empty-title">No projects yet</div>
                <p class="empty-sub">You haven't created any projects. Start one and build your team.</p>
                <a href="/student/create/projects" class="btn-primary">+ Create your first project</a>
            </div>

        <% } %>

    </div>

    <footer class="footer">
        <div class="footer-inner">
            <span class="footer-logo">Team<span>Match</span></span>
            <span class="footer-copy">University Project Collaboration Platform</span>
        </div>
    </footer>


    <!-- ===== DELETE CONFIRMATION MODAL ===== -->
    <div class="modal-backdrop" id="modalBackdrop" onclick="closeDeleteModal()">
        <div class="modal" id="deleteModal" onclick="event.stopPropagation()">

            <div class="modal-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
            </div>

            <h3 class="modal-title" onclick="deleteProject()">Delete Project</h3>
            <p class="modal-body">
                You're about to permanently delete <strong id="modalProjectName"></strong>.
                All applications linked to this project will also be removed. This cannot be undone.
            </p>

            <div class="modal-actions">
                <button class="modal-cancel" onclick="closeDeleteModal()">Cancel</button>
                <a class="modal-confirm" id="modalConfirmBtn" href="#">Delete Project</a>
            </div>

        </div>
    </div>


    <script>
        function openDeleteModal(btn) {
            const title = btn.dataset.title;
            const href  = btn.dataset.href;

            document.getElementById('modalProjectName').textContent = title;
            document.getElementById('modalConfirmBtn').setAttribute('href', href);

            document.getElementById('modalBackdrop').classList.add('visible');
            document.body.style.overflow = 'hidden';
        }

        function closeDeleteModal() {
            document.getElementById('modalBackdrop').classList.remove('visible');
            document.body.style.overflow = '';
        }

        // Close on Escape key
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeDeleteModal();
        });

    </script>

</body>
</html>
