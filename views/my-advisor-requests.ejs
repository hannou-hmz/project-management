<h1>My Advisor Requests</h1>

<% if (requests && requests.length > 0) { %>

    <% requests.forEach(req => { %>

        <div style="border: 1px solid #ccc; padding: 15px; margin-bottom: 20px; border-radius: 10px;">

            <p><strong>Student ID:</strong> <%= req.user_id %></p>
            <p><strong>Full Name:</strong> <%= req.full_name %></p>
            <p><strong>Email:</strong> <%= req.email %></p>
            <p><strong>Department:</strong> <%= req.department_name %></p>

            <hr>

            <p><strong>Project Title:</strong> <%= req.project_title %></p>
            <p><strong>Project Description:</strong> <%= req.project_description %></p>

            <p><strong>Category:</strong> <%= req.category_name %></p>

            <hr>

            <p><strong>Message:</strong> <%= req.request_message %></p>

            <p><strong>Meeting Method:</strong> 
                <%= req.meeting_method === "online" ? "Online 💻" : "In Person 🏫" %>
            </p>

            <p><strong>Status:</strong> <%= req.status %></p>

            <p><strong>Requested At:</strong> 
                <%= req.requested_at %>
            </p>

        </div>

    <% }) %>

<% } else { %>

    <p>No requests found.</p>

<% } %>