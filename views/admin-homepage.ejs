<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin — TeamMatch</title>
<link rel="stylesheet" href="/admin-styling/admin-homepage.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<!-- ═══════════════════════════════════════
     SIDEBAR
════════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">

  <!-- Brand -->
  <div class="sb-brand">
    <div class="sb-logo">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor"/><path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/><path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
    </div>
    <div class="sb-brand-text">
      <span class="sb-name">Team<em>Match</em></span>
      <span class="sb-role">Admin Console</span>
    </div>
  </div>

  <!-- Nav -->
  <nav class="sb-nav">
    <div class="sb-nav-label">Main Menu</div>

    <a href="/admin/homepage" class="sb-link active">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
      </span>
      <span class="sb-link-label">Dashboard</span>
    </a>

    <a href="/admin/categories" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      </span>
      <span class="sb-link-label">Categories</span>
    </a>

    <a href="/admin/projects" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      </span>
      <span class="sb-link-label">Projects</span>
    </a>

    <a href="/admin/announcements" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      </span>
      <span class="sb-link-label">Announcements</span>
    </a>

    <a href="/admin/users/roles" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </span>
      <span class="sb-link-label">Users &amp; Roles</span>
    </a>
  </nav>

  <!-- Sidebar Footer -->
  <div class="sb-footer">
    <div class="sb-admin-row">
      <div class="sb-avatar">A</div>
      <div class="sb-admin-info">
        <div class="sb-admin-name">Admin</div>
        <div class="sb-admin-sub">Super Admin</div>
      </div>
      <a href="/logout" class="sb-logout-btn" title="Logout">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    </div>
  </div>

</aside>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ═══════════════════════════════════════
     LAYOUT MAIN
════════════════════════════════════════ -->
<div class="layout-main">

  <!-- ── Topbar ── -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="mobile-toggle" onclick="toggleSidebar()" aria-label="Toggle sidebar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-breadcrumb">
        <span class="tb-root">TeamMatch</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="tb-current">Dashboard</span>
      </div>
    </div>
    <div class="topbar-right">
      <div class="topbar-date" id="topbarDate"></div>
      <div class="tb-sep"></div>
      <div class="topbar-status">
        <span class="status-dot"></span>
        <span>System operational</span>
      </div>
    </div>
  </header>

  <!-- ── Page content ── -->
  <main class="page-content">

    <!-- Page heading -->
    <div class="page-heading">
      <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Platform overview &mdash; all systems running.</p>
      </div>
      <div class="page-clock">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span id="liveTime"></span>
      </div>
    </div>

    <!-- ── Stats ── -->
    <div class="stats-grid">

      <div class="stat-card sc-blue">
        <div class="stat-top">
          <div class="stat-icon-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <span class="stat-live">● Live</span>
        </div>
        <div class="stat-num"><%= projects.total_projects %></div>
        <div class="stat-label">Total Projects</div>
        <div class="stat-hint">across all categories</div>
      </div>

      <div class="stat-card sc-green">
        <div class="stat-top">
          <div class="stat-icon-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <span class="stat-live">● Live</span>
        </div>
        <div class="stat-num"><%= users.total_users%></div>
        <div class="stat-label">Registered Users</div>
        <div class="stat-hint">students &amp; instructors</div>
      </div>

      <div class="stat-card sc-amber">
        <div class="stat-top">
          <div class="stat-icon-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </div>
          <span class="stat-live">● Live</span>
        </div>
        <div class="stat-num"><%= announcements.total_announcements%></div>
        <div class="stat-label">Announcements</div>
        <div class="stat-hint">published platform-wide</div>
      </div>

      <div class="stat-card sc-coral">
        <div class="stat-top">
          <div class="stat-icon-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
          </div>
          <span class="stat-live">● Live</span>
        </div>
        <div class="stat-num"><%= categories.total_categories%></div>
        <div class="stat-label">Categories</div>
        <div class="stat-hint">project classification types</div>
      </div>

    </div>

    <!-- ── Manage Sections ── -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-header-left">
          <h2 class="panel-title">Manage Sections</h2>
          <p class="panel-sub">Select a module to manage its content and settings.</p>
        </div>
      </div>
      <div class="panel-body">

        <a href="/admin/categories" class="mc-row">
          <div class="mc-icon mc-coral">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
          </div>
          <div class="mc-info">
            <div class="mc-title">Categories</div>
            <div class="mc-desc">Create, edit, and remove project categories used across the platform</div>
          </div>
          <div class="mc-meta">
            <span class="mc-count"><%= categories.total_categories %> items</span>
          </div>
          <div class="mc-cta">
            Manage
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>

        <a href="/admin/projects" class="mc-row">
          <div class="mc-icon mc-blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div class="mc-info">
            <div class="mc-title">Projects</div>
            <div class="mc-desc">View and moderate all student-created projects across every department</div>
          </div>
          <div class="mc-meta">
            <span class="mc-count"><%= projects.total_projects %> items</span>
          </div>
          <div class="mc-cta">
            Manage
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>

        <a href="/admin/announcements" class="mc-row">
          <div class="mc-icon mc-amber">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </div>
          <div class="mc-info">
            <div class="mc-title">Announcements</div>
            <div class="mc-desc">Publish platform-wide notices, deadlines, and urgent alerts to all users</div>
          </div>
          <div class="mc-meta">
            <span class="mc-count"><%= announcements.total_announcements %> items</span>
          </div>
          <div class="mc-cta">
            Manage
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>

        <a href="/admin/users/roles" class="mc-row mc-row-last">
          <div class="mc-icon mc-green">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div class="mc-info">
            <div class="mc-title">Users &amp; Roles</div>
            <div class="mc-desc">Manage user accounts, assign permissions, and control role access levels</div>
          </div>
          <div class="mc-meta">
            <span class="mc-count"><%= users.total_users %> users</span>
          </div>
          <div class="mc-cta">
            Manage
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>

      </div>
    </div>

  </main>
</div>

<!-- ═══════════════════════════════════════
     SCRIPTS
════════════════════════════════════════ -->
<script>
  // Live date in topbar
  const el = document.getElementById('topbarDate');
  if (el) {
    const now = new Date();
    el.textContent = now.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  }

  // Live clock
  function updateClock() {
    const t = document.getElementById('liveTime');
    if (t) t.textContent = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 1000);

  // Mobile sidebar
  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebarOverlay').classList.toggle('visible');
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('visible');
  }

  // Stagger-in stat cards on load
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.stat-card').forEach((card, i) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(16px)';
      setTimeout(() => {
        card.style.transition = 'opacity .45s ease, transform .45s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
      }, 80 + i * 70);
    });
    document.querySelectorAll('.mc-row').forEach((row, i) => {
      row.style.opacity = '0';
      row.style.transform = 'translateX(-8px)';
      setTimeout(() => {
        row.style.transition = 'opacity .4s ease, transform .4s ease';
        row.style.opacity = '1';
        row.style.transform = 'translateX(0)';
      }, 320 + i * 60);
    });
  });
</script>

</body>
</html>
