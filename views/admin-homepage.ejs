<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel</title>
  <link rel="stylesheet" href="/styling/admin-homepage.css">
  <link rel="icon" href="/img/fav.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
</head>
<body>

  <!-- NAVIGATION -->
  <nav class="navbar">
    <a href="/admin/dashboard" class="nav-logo">Team<span>Match</span> <span class="admin-badge">Admin</span></a>

    <div class="nav-links">
      <a href="/admin/categories" class="nav-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Categories
      </a>
      <a href="/admin/projects" class="nav-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Projects
      </a>
      <a href="/admin/announcements" class="nav-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        Announcements
      </a>
      <a href="/admin/users/roles" class="nav-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Users & Roles
      </a>
    </div>

    <a href="/logout" class="nav-btn-logout">Logout</a>
  </nav>

  <!-- CONTENT -->
  <div class="container">

    <!-- Hero -->
    <div class="hero">
      <div class="hero-inner">
        <div class="hero-eyebrow">Admin Panel</div>
        <h1 class="hero-title">Welcome to the<br><em>Control Centre</em></h1>
        <p class="hero-sub">Manage categories, projects, announcements, and user roles from one place.</p>
      </div>
      <div class="hero-orb"></div>
    </div>

    <!-- Quick Access -->
    <div class="section-header">
      <h2 class="section-title">Quick Access</h2>
      <p class="section-sub">Jump directly to any section.</p>
    </div>

    <div class="quick-grid">

      <a href="/admin/categories" class="quick-card">
        <div class="quick-icon qc-amber">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <div class="quick-text">
          <div class="quick-title">Categories</div>
          <div class="quick-desc">Create and manage project categories across the platform</div>
        </div>
        <div class="quick-arrow">→</div>
      </a>

      <a href="/admin/projects" class="quick-card qc-featured">
        <div class="quick-icon qc-blue">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/></svg>
        </div>
        <div class="quick-text">
          <div class="quick-title">Projects</div>
          <div class="quick-desc">View, moderate, and oversee all student projects</div>
        </div>
        <div class="quick-arrow">→</div>
      </a>

      <a href="/admin/announcements" class="quick-card">
        <div class="quick-icon qc-coral">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <div class="quick-text">
          <div class="quick-title">Announcements</div>
          <div class="quick-desc">Publish platform-wide notices and urgent alerts</div>
        </div>
        <div class="quick-arrow">→</div>
      </a>

      <a href="/admin/users/roles" class="quick-card">
        <div class="quick-icon qc-green">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="quick-text">
          <div class="quick-title">Users & Roles</div>
          <div class="quick-desc">Manage user accounts, permissions, and role assignments</div>
        </div>
        <div class="quick-arrow">→</div>
      </a>

    </div>

  </div>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-logo">Team<span>Match</span></span>
      <span class="footer-copy">Admin Panel · University Project Collaboration Platform</span>
    </div>
  </footer>

</body>
</html>
