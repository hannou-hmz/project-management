<h1>Announcements</h1>

<% if (announcements && announcements.length > 0) { %>

    <% announcements.forEach(ann => { %>

        <div style="margin-bottom: 20px;">

            <h3><%= ann.title %></h3>

            <!-- <p><strong>ID:</strong> <%= ann.announcement_id %></p> -->

            <p><strong>Category:</strong> <%= ann.category_name %></p>

            <p><strong>Description:</strong> <%= ann.description %></p>

            <p><strong>Created At:</strong> 
                <%= ann.created_at %>
            </p>

            <p><strong>Urgent:</strong> 
                <%= ann.is_urgent ? "Yes 🔴" : "No" %>
            </p>

            <form action="/admin/announcements/<%= ann.announcement_id%>/delete?_method=DELETE" method="POST">
                <button type="submit">Delete</button>

            </form>

            <form action="/admin/announcements/add" method="GET">
                <button type="submit">Add</button>
            </form>


        </div>

        <hr>

    <% }) %>

<% } else { %>

    <a style="padding: 7px; background-color: black; color: white;" 
            href="/admin/announcements/add">Add</a>
    <p>No announcements found.</p>

<% } %>