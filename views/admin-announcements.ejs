<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Announcements — Admin</title>
<link rel="stylesheet" href="/styling/admin-announcements.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
</head>
<body>

<!-- ===== SIDEBAR ===== -->
<aside class="sidebar">
    <div class="sidebar-brand">
        Team<span>Match</span>
        <div class="sidebar-badge">Admin</div>
    </div>
    <div class="sidebar-section-label">Navigation</div>
    <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="sidebar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
        </a>
        <a href="/admin/categories" class="sidebar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            Categories
        </a>
        <a href="/admin/projects" class="sidebar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Projects
        </a>
        <a href="/admin/announcements" class="sidebar-link active">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            Announcements
        </a>
        <a href="/admin/users/roles" class="sidebar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Users & Roles
        </a>
    </nav>
    <div class="sidebar-footer">
        <a href="/logout" class="sidebar-logout">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Logout
        </a>
    </div>
</aside>

<!-- ===== MAIN ===== -->
<main class="main">

    <!-- Topbar -->
    <div class="topbar">
        <div class="topbar-left">
            <div class="topbar-title">Announcements</div>
            <div class="topbar-sub">Publish and manage platform-wide notices</div>
        </div>
        <button class="btn-add" onclick="openAddModal()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Announcement
        </button>
    </div>

    <div class="content">

        <% if (announcements && announcements.length > 0) { %>

            <div class="count-bar">
                <span>
                    <strong><%= announcements.length %></strong> announcement<%= announcements.length !== 1 ? 's' : '' %>
                </span>
                <% const urgentCount = announcements.filter(a => a.is_urgent).length; %>
                <% if (urgentCount > 0) { %>
                    <span class="urgent-pill">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        <%= urgentCount %> urgent
                    </span>
                <% } %>
            </div>

            <!-- Table -->
            <div class="data-table">
                <div class="table-head">
                    <div class="th">Title</div>
                    <div class="th">Category</div>
                    <div class="th">Description</div>
                    <div class="th">Urgent</div>
                    <div class="th">Created</div>
                    <div class="th th-action">Action</div>
                </div>

                <% announcements.forEach(ann => { %>
                <div class="table-row <%= ann.is_urgent ? 'row-urgent' : '' %>">

                    <div class="td td-title">
                        <% if (ann.is_urgent) { %>
                        <span class="urgent-dot" title="Urgent"></span>
                        <% } %>
                        <%= ann.title %>
                    </div>

                    <div class="td">
                        <span class="cat-badge"><%= ann.category_name %></span>
                    </div>

                    <div class="td td-desc"><%= ann.description %></div>

                    <div class="td">
                        <% if (ann.is_urgent) { %>
                            <span class="badge-urgent">Urgent</span>
                        <% } else { %>
                            <span class="badge-normal">No</span>
                        <% } %>
                    </div>

                    <div class="td td-date">
                        <%= new Date(ann.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    </div>

                    <div class="td td-actions">
                        <button class="delete-btn"
                                data-title="<%= ann.title %>"
                                data-id="<%= ann.announcement_id %>"
                                onclick="openDeleteModal(this)">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                            Delete
                        </button>
                    </div>

                </div>
                <% }) %>

            </div>

        <% } else { %>

            <div class="empty-state">
                <div class="empty-icon">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                </div>
                <div class="empty-title">No announcements yet</div>
                <p class="empty-sub">Publish your first announcement to notify all platform users.</p>
                <button class="btn-add" onclick="openAddModal()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    New Announcement
                </button>
            </div>

        <% } %>

    </div>
</main>


<!-- ===== ADD ANNOUNCEMENT MODAL ===== -->
<div class="modal-backdrop" id="addBackdrop" onclick="closeAddModal()">
    <div class="modal modal-wide" onclick="event.stopPropagation()">

        <div class="modal-header">
            <div class="modal-header-left">
                <div class="modal-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                </div>
                <h3 class="modal-title">New Announcement</h3>
            </div>
            <button class="modal-close" onclick="closeAddModal()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <form action="/admin/announcements/add" method="POST">

            <div class="modal-body">

                <!-- Category -->
                <div class="field-group">
                    <label class="field-label" for="category">Category <span class="required">*</span></label>
                    <select class="field-input field-select" name="category" id="category" required>
                        <option value="">Select your category</option>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat.category_id %>">
                                <%= cat.category_name %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <!-- Title -->
                <div class="field-group">
                    <label class="field-label" for="title">Title <span class="required">*</span></label>
                    <input class="field-input" id="title" name="title" placeholder="Announcement title" required>
                </div>

                <!-- Description -->
                <div class="field-group">
                    <label class="field-label" for="desc">Description <span class="required">*</span></label>
                    <textarea class="field-textarea" id="desc" name="description" rows="5"
                                placeholder="Write the full announcement content here..." required></textarea>
                </div>

                <!-- Urgent toggle -->
                <div class="urgent-toggle-wrap">
                    <div class="urgent-toggle-left">
                        <div class="urgent-icon">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        </div>
                        <div>
                            <div class="urgent-toggle-title">Mark as Urgent</div>
                            <div class="urgent-toggle-sub">Urgent announcements are visually highlighted for all users</div>
                        </div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" name="isUrgent" id="urgentCheck" value="true">
                        <span class="toggle-slider"></span>
                    </label>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeAddModal()">Cancel</button>
                <button id="add-btn" type="submit" class="btn-submit">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    Publish Announcement
                </button>
            </div>

        </form>
    </div>
</div>


<!-- ===== DELETE MODAL ===== -->
<div class="modal-backdrop" id="deleteBackdrop" onclick="closeDeleteModal()">
    <div class="modal" onclick="event.stopPropagation()">

        <div class="modal-icon-del">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </div>

        <h3 class="modal-title">Delete Announcement</h3>
        <p class="modal-del-body">
            Are you sure you want to delete <strong id="deleteAnnTitle"></strong>?
            This will remove it from all user feeds immediately.
        </p>

        <!-- Delete uses POST with _method=DELETE as in original -->
        <form id="deleteForm" action="" method="POST">
            <input type="hidden" name="_method" value="DELETE">
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button type="submit" class="btn-del-confirm">Delete</button>
            </div>
        </form>

    </div>
</div>


<script>
    // ===== ADD MODAL =====
    function openAddModal() {
        document.getElementById('addBackdrop').classList.add('visible');
        document.body.style.overflow = 'hidden';
        setTimeout(() => document.getElementById('title').focus(), 60);
    }
    function closeAddModal() {
        document.getElementById('addBackdrop').classList.remove('visible');
        document.body.style.overflow = '';
    }

    // ===== DELETE MODAL =====
    function openDeleteModal(btn) {
        const id    = btn.dataset.id;
        const title = btn.dataset.title;
        document.getElementById('deleteAnnTitle').textContent = title;
        document.getElementById('deleteForm').setAttribute(
            'action',
            '/admin/announcements/' + id + '/delete?_method=DELETE'
        );
        document.getElementById('deleteBackdrop').classList.add('visible');
        document.body.style.overflow = 'hidden';
    }
    function closeDeleteModal() {
        document.getElementById('deleteBackdrop').classList.remove('visible');
        document.body.style.overflow = '';
    }

    // Close on Escape
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { closeAddModal(); closeDeleteModal(); }
    });
</script>

</body>
</html>
