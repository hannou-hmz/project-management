<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Change Password</title>
    <link rel="stylesheet" href="/styling/st-change-password.css">
</head>
<body>

<div class="auth-container">

    <h2>Change Password</h2>

    <% if (typeof error !== "undefined" && error) { %>
        <div class="alert error"><%= error %></div>
    <% } %>

    <% if (typeof success !== "undefined" && success) { %>
        <div class="alert success"><%= success %></div>
    <% } %>

    <form id="passwordForm" action="/student/profile/change-password" method="POST">

        <div class="form-group">
            <label>Current Password</label>
            <input type="password" name="currentPassword" required>
        </div>

        <div class="form-group">
            <label>New Password</label>
            <input type="password" id="newPassword" name="newPassword" required>
            <small class="error-msg" id="newPasswordError"></small>
        </div>

        <div class="form-group">
            <label>Confirm New Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" required>
            <small class="error-msg" id="confirmPasswordError"></small>
        </div>

        <button type="submit">Update Password</button>

    </form>

</div>

<script>
    const form = document.getElementById("passwordForm");

    form.addEventListener("submit", function (e) {
        let valid = true;

        const newPass = document.getElementById("newPassword");
        const confirmPass = document.getElementById("confirmPassword");

        const newError = document.getElementById("newPasswordError");
        const confirmError = document.getElementById("confirmPasswordError");

        newError.textContent = "";
        confirmError.textContent = "";

        if (newPass.value.length < 6) {
            newError.textContent = "Password must be at least 6 characters.";
            valid = false;
        }

        if (newPass.value !== confirmPass.value) {
            confirmError.textContent = "Passwords do not match.";
            valid = false;
        }

        if (!valid) {
            e.preventDefault();
        }
    });
</script>

</body>
</html>