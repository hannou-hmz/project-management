<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Create a New Project</title>
<link rel="stylesheet" href="/student-styling/create-projects.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<!-- Navbar -->
<nav class="navbar">
    <a class="nav-logo" href="/student/homepage">Team<span>Match</span></a>
    <div class="nav-actions">
        <a href="/student/projects" class="nav-btn-outline">Browse Projects</a>
        <a href="/student/homepage" class="nav-btn-outline">Dashboard</a>
        <a href="/logout" class="nav-btn-logout">Logout</a>
    </div>
</nav>

<div class="page-wrap">

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-eyebrow">Student Portal</div>
            <h1 class="page-title">Create a New Project</h1>
            <p class="page-sub">Fill in the details below to post your project and start building your team.</p>
        </div>
    </div>

    <!-- Form Layout -->
    <div class="form-layout">

        <!-- Main Form -->
        <div class="form-main">
            <form action="/student/create/projects" method="POST" id="projectForm">

                <!-- Project Title -->
                <div class="card">
                    <div class="card-header">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Project Basics
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="title">Project Title <span class="required">*</span></label>
                        <input class="form-input" type="text" id="title" name="title" placeholder="e.g. AI-Powered Study Assistant" required>
                    </div>
                    
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" for="category">Category <span class="required">*</span></label>
                        <select class="form-input form-select" id="category" name="category" required>
                            <option value="">-- Select a category --</option>
                            <% categories.forEach(category => { %>
                                <option value="<%= category.category_id %>">
                                    <%= category.category_name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <!-- Description -->
                <div class="card">
                    <div class="card-header">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                        Description
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" for="description">Tell students what this project is about <span class="required">*</span></label>
                        <textarea class="form-textarea" id="description" name="description" rows="5" placeholder="Describe your project goals, what you'll be building, and what you hope to achieve..." required></textarea>
                        <p class="input-hint">Be specific — a good description attracts the right teammates.</p>
                    </div>
                </div>

                <!-- Skills -->
                <div class="card">
                    <div class="card-header">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                        Required Skills
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" for="skills">Skills needed for this project</label>
                        <input class="form-input" type="text" id="skills" name="skills" placeholder="e.g. Python, React, Machine Learning, UI/UX">
                        <p class="input-hint">Separate skills with commas. These appear as tags on your project listing.</p>
                    </div>
                </div>

                <!-- Team & Budget -->
                <div class="card">
                    <div class="card-header">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Team & Budget
                    </div>

                    <div class="two-col">
                        <!-- Team Size -->
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">Team Size <span class="required">*</span></label>
                            <div class="team-size-controls">
                                <button type="button" class="ts-btn" id="decreaseTeam">−</button>
                                <div class="ts-display">
                                    <span id="teamSize">1</span>
                                    <span class="ts-unit">members</span>
                                </div>
                                <input type="hidden" id="teamSizeInput" name="teamSize" value="1" min="1">
                                <button type="button" class="ts-btn" id="increaseTeam">+</button>
                            </div>
                        </div>

                        <!-- Budget -->
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label" for="budget">Budget (₺) <span class="required">*</span></label>
                            <div class="input-prefix-wrap">
                                <span class="input-prefix">₺</span>
                                <input class="form-input input-with-prefix" type="number" id="budget" name="budget" min="0" placeholder="0" required>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Advisor Toggle -->
                <div class="card advisor-card">
                    <div class="advisor-toggle-row">
                        <div class="advisor-toggle-left">
                            <div class="advisor-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                            <div>
                                <div class="advisor-toggle-title">Require an Advisor?</div>
                                <div class="advisor-toggle-sub">Your project will be listed as seeking faculty guidance</div>
                            </div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" name="reqAdvisor" id="myCheckbox" value="0">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" id="create-btn" class="submit-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                    Create Project
                </button>

            </form>
        </div>

        <!-- Sidebar Tips -->
        <div class="form-sidebar">
            <div class="tip-card">
                <div class="tip-header">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Tips for a great listing
                </div>
                <ul class="tip-list">
                    <li>Use a clear, specific title that explains the project at a glance</li>
                    <li>Write at least 3–4 sentences in your description</li>
                    <li>List the exact skills you need — this helps with matching</li>
                    <li>Set a realistic team size before posting</li>
                    <li>Enable advisor requirement if your category needs faculty oversight</li>
                </ul>
            </div>

            <div class="tip-card categories-card">
                <div class="tip-header">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    About categories
                </div>
                <div class="category-info">
                    <div class="ci-item">
                        <div class="ci-name">TUBITAK</div>
                        <div class="ci-desc">National scientific research grant projects</div>
                    </div>
                    <div class="ci-item">
                        <div class="ci-name">Teknofest</div>
                        <div class="ci-desc">Turkey's largest technology competition</div>
                    </div>
                    <div class="ci-item">
                        <div class="ci-name">Course Project</div>
                        <div class="ci-desc">Academic coursework and semester projects</div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<footer class="footer">
    <div class="footer-inner">
        <span class="footer-logo">Team<span>Match</span></span>
        <span class="footer-copy">University Project Collaboration Platform</span>
    </div>
</footer>

<script>
    // Team size logic
    let teamSize = 1;

    const teamSizeSpan = document.getElementById('teamSize');
    const teamSizeInput = document.getElementById('teamSizeInput');

    document.getElementById('increaseTeam').addEventListener('click', () => {
        teamSize++;
        teamSizeSpan.textContent = teamSize;
        teamSizeInput.value = teamSize; // important
    });

    document.getElementById('decreaseTeam').addEventListener('click', () => {
        if (teamSize > 1) teamSize--;
        teamSizeSpan.textContent = teamSize;
        teamSizeInput.value = teamSize; // important
    });

    // const createBtn = document.getElementById('create-btn');
    // createBtn.addEventListener("click" , (event)=>{
    //     event.preventDefault();
    //     window.location.href = '/student/homepage'
    // });

    const checkbox = document.getElementById('myCheckbox');

    checkbox.addEventListener('change', () => {
        if (checkbox.checked) {
            checkbox.value = "1"; // checked → 1
        } else {
            checkbox.value = "0"; // unchecked → 0
        }
    });
</script>

</body>
</html>
