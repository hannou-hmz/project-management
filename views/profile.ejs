<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>

    <div class="form-group">
            <label>Change Photo:</label>
            <input type="file" name="photo" id="photo">
        </div>

 <form action="/profile/edit" method="POST" enctype="multipart/form-data"></form>

        <img id="preview"
         src="../static-files/profile-photos/default.jpg <%= profile_photo || 'default.jpg' %>"
         alt="Profile Photo">

    <div class="form-group">
            <label>Full Name:</label>
            <input type="text" value="<%= fullName %>" readonly>
        </div>

        <!-- DEPARTMENT (READ ONLY) -->
        <div class="form-group">
            <label>Department:</label>
            <input type="text" value="<%= department %>" readonly>
        </div>

        <!-- EMAIL (READ ONLY) -->
        <div class="form-group">
            <label>Email:</label>
            <input type="email" value="<%= email %>" readonly>
        </div>

        <!-- SKILLS (EDITABLE) -->
        <div class="form-group">
            <label>Skills:</label>
            <input type="text" name="skills" value="<%= skills %>">
        </div>

        <!-- BIO (EDITABLE) -->
        <div class="form-group">
            <label>Bio:</label>
            <textarea name="bio" rows="4"><%= bio %></textarea>
        </div>

        <button type="submit">Update Profile</button>
    </form>

</div>

