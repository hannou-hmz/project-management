<div class="container">
    <h1>🔔 Announcements</h1>

    <form action="/admin/announcements/add" method="POST">
        <div class="card">

        <select name="category">
            <option value="">Select your category</option>
            <% categories.forEach(cat => { %>
                <option value="<%= cat.category_id %>">
                    <%= cat.category_name %>
                </option>
            <% }) %>
        </select>
        <br>
        <br>
        <input id="title" name="title" placeholder="Title" />
        <br>
        <br>
        <textarea id="desc" name="description" placeholder="Description"></textarea>

        <br>
        <br>
        <div class="row">
            <div class="switch">
            <label for="urgentCheck">is urgent</label>
            <input type="checkbox" name="isUrgent" id="urgentCheck" value="true" />
            </div>
        </div>

        <br>
        <button id="add-btn" type="submit">Add</button>
        </div>

        <div id="list"></div>
    </form>
    
  </div>