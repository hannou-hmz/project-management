<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Projects — Advisor · TeamMatch</title>
<link rel="stylesheet" href="/advisor-styling/advisor-projects.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<%
const isAvailable = !!(advisor && (advisor.is_available || advisor.available));
%>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ═══════════════════════════════════════
     SIDEBAR
════════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">

  <div class="sb-brand">
    <div class="sb-logo">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor"/><path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/><path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
    </div>
    <div class="sb-brand-text">
      <a href="/advisor/dashboard" class="sb-name">Team<em>Match</em></a>
      <span class="sb-role">Advisor Portal</span>
    </div>
  </div>

  <!-- Advisor identity card -->
  <% if (typeof advisor !== 'undefined' && advisor) { %>
  <div class="sb-profile" onclick="window.location.href='/advisor/profile'" title="View profile">
    <div class="sp-avatar">
      <%= advisor.full_name ? advisor.full_name.split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase() : 'AD' %>
    </div>
    <div class="sp-info">
      <div class="sp-name"><%= advisor.full_name || 'Advisor' %></div>
      <% if (advisor.academic_title) { %>
      <div class="sp-title"><%= advisor.academic_title %></div>
      <% } %>
    </div>
    <div class="sp-avail-dot <%= isAvailable ? 'dot-on' : 'dot-off' %>"></div>
  </div>

  <div class="sb-avail-strip <%= isAvailable ? 'avail-on' : 'avail-off' %>">
    <span class="sa-label"><%= isAvailable ? 'Available for advising' : 'Not accepting requests' %></span>
    <a href="/advisor/profile" class="sa-link">Change →</a>
  </div>
  <% } %>

  <div class="sb-divider"></div>

  <nav class="sb-nav">
    <div class="sb-nav-label">Navigation</div>

    <a href="/advisor/dashboard" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
      </span>
      <span class="sb-link-label">Dashboard</span>
    </a>

    <a href="/advisor/projects" class="sb-link active">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/></svg>
      </span>
      <span class="sb-link-label">My Projects</span>
    </a>

    <a href="/advisor/requests" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </span>
      <span class="sb-link-label">Student Requests</span>
    </a>

    <a href="/advisor/profile" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </span>
      <span class="sb-link-label">My Profile</span>
    </a>
  </nav>

  <div class="sb-footer">
    <a href="/logout" class="sb-logout-btn">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Logout
    </a>
  </div>

</aside>

<!-- ═══════════════════════════════════════
     LAYOUT MAIN
════════════════════════════════════════ -->
<div class="layout-main">

  <!-- ── Topbar ── -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="mobile-toggle" onclick="toggleSidebar()" aria-label="Toggle sidebar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-breadcrumb">
        <span class="tb-root">TeamMatch</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="tb-current">My Projects</span>
      </div>
    </div>
    <div class="topbar-right">
      <% if (projects && projects.length > 0) { %>
      <div class="topbar-count">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <strong><%= projects.length %></strong>&nbsp;project<%= projects.length !== 1 ? 's' : '' %>
      </div>
      <% } %>
    </div>
  </header>

  <!-- ── Page content ── -->
  <main class="page-content">

    <div class="page-heading">
      <div>
        <h1 class="page-title">My Projects</h1>
        <p class="page-subtitle">Projects you are currently assigned to advise.</p>
      </div>
    </div>

    <% if (projects && projects.length > 0) { %>

    <div class="projects-grid">

      <% projects.forEach(p => { %>
      <div class="project-card">

        <!-- Card top accent bar via CSS -->

        <div class="pc-top">

          <!-- Header row -->
          <div class="pc-header">
            <h3 class="pc-title"><%= p.project_title %></h3>
            <div class="pc-badges">

              <span class="badge badge-meeting">
                <% if (p.meeting_method === 'online') { %>
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                  Online
                <% } else { %>
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  In Person
                <% } %>
              </span>

              <span class="badge badge-budget">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                $<%= Number(p.budget).toLocaleString() %>
              </span>

            </div>
          </div>

          <!-- Description -->
          <p class="pc-desc"><%= p.project_description %></p>

        </div>

        <!-- Student info footer -->
        <div class="pc-footer">
          <div class="student-row">
            <div class="student-avatar">
              <%= p.full_name ? p.full_name.charAt(0).toUpperCase() : 'S' %>
            </div>
            <div class="student-info">
              <div class="student-name"><%= p.full_name %></div>
              <div class="student-email">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <%= p.email %>
              </div>
            </div>
            <span class="student-label">Project Lead</span>
          </div>
        </div>

      </div>
      <% }) %>

    </div>

    <% } else { %>

    <!-- Empty State -->
    <div class="panel">
      <div class="empty-state">
        <div class="empty-icon-wrap">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div class="empty-title">No projects assigned yet</div>
        <p class="empty-sub">You haven't been assigned to any projects. Students can request your advising from the platform.</p>
        <a href="/advisor/profile" class="btn-primary">Check your availability</a>
      </div>
    </div>

    <% } %>

  </main>
</div>

<script>
  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebarOverlay').classList.toggle('visible');
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('visible');
  }

  // Stagger cards on load
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.project-card').forEach((card, i) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(14px)';
      setTimeout(() => {
        card.style.transition = 'opacity .4s ease, transform .4s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
      }, 60 + i * 60);
    });
  });
</script>

</body>
</html>
