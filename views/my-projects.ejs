<h1>All my Projects</h1>

<% if (projects && projects.length > 0) { %>

    <% projects.forEach(project => { %>

        <div style="margin-bottom: 20px;">

            <h3><%= project.project_title %></h3>

            <!-- <input type="hidden" name="project_id" value="<%= project.project_id %>"> -->

            <p><strong>Category :</strong> <%= project.category_name %></p>

            <p><strong>Description:</strong> <%= project.project_description %></p>

            <p><strong>Budget:</strong> <%= project.budget %> USD</p>

            <p><strong>Required Skills:</strong> <%= project.required_skills %></p>

            <p><strong>Team Size:</strong> <%= project.team_size %></p>

            <p><strong>Require Advisor:</strong> <%= project.require_advisor ? "Yes" : "No" %></p>

            <p><strong>Created At:</strong> 
                <%= project.created_at %>
            </p>

            <!-- Apply Button -->
            <a style="background-color: blue; color: white; padding: 8px;"
                href="/student/<%= project.project_id %>/delete">
                delete
            </a>

        </div>

        <hr>

    <% }) %>

<% } else { %>

    <p>No projects found.</p>

<% } %>