<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Advisor Requests</title>
    <link rel="icon" href="/img/fav.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/student-styling/st-advisor-requests.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <a class="nav-logo" href="/student/homepage">Team<span>Match</span></a>
        <div class="nav-links">
            <a href="/student/projects" class="nav-link">Browse Projects</a>
            <a href="/student/myprojects" class="nav-link">My Projects</a>
            <a href="/student/applications" class="nav-link">My Applications</a>
            <a href="/student/announcements" class="nav-link">Announcements</a>
            <a href="/student/find/advisors" class="nav-link">Find Advisor</a>
            <a href="/student/requests" class="nav-link">Requests Advisor</a>
            <a href="/student/applicants" class="nav-link">Applicants</a>
        </div>
        <div class="nav-actions">
            <a href="/student/profile" class="nav-btn-outline">Profile</a>
            <a href="/logout" class="nav-btn-logout">Logout</a>
        </div>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-eyebrow">Advisor Requests</div>
            <h1 class="page-title">My Requests</h1>
            <p class="page-sub">Track the status of your advisor requests for each project.</p>
        </div>
    </div>

    <div class="container">

        <% if (requests && requests.length > 0) { %>

            <!-- Toolbar -->
            <div class="toolbar">
                <span class="results-count">
                    <strong><%= requests.length %></strong> request<%= requests.length !== 1 ? 's' : '' %>
                </span>
                <a href="/student/find/advisors" class="btn-outline">Find more advisors →</a>
            </div>

            <!-- Requests List -->
            <div class="requests-list">

                <% requests.forEach(req => { %>
                <div class="req-card">

                    <div class="req-body">

                        <!-- Header -->
                        <div class="req-header">
                            <div class="req-header-left">
                                <h3 class="req-title"><%= req.project_title %></h3>
                                <div class="req-badges">
                                    <span class="badge badge-category"><%= req.category_name %></span>

                                    <!-- Meeting method badge -->
                                    <span class="badge badge-meeting">
                                        <% if (req.meeting_method === 'online') { %>
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                                            Online
                                        <% } else { %>
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                            In Person
                                        <% } %>
                                    </span>

                                    <span class="badge badge-date">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                        <%= new Date(req.requested_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                    </span>
                                </div>
                            </div>

                            <!-- Status pill -->
                            <%
                                let statusClass = 'status-pending';
                                if (req.status === 'accepted')  statusClass = 'status-accepted';
                                if (req.status === 'rejected')  statusClass = 'status-rejected';
                            %>
                            <span class="status-pill <%= statusClass %>">
                                <% if (req.status === 'accepted') { %>
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <% } else if (req.status === 'rejected') { %>
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                <% } else { %>
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                <% } %>
                                <%= req.status.charAt(0).toUpperCase() + req.status.slice(1) %>
                            </span>
                        </div>

                        <!-- Project description -->
                        <p class="req-desc"><%= req.project_description %></p>

                        <!-- Message box -->
                        <% if (req.request_message) { %>
                        <div class="req-message-wrap">
                            <div class="req-message-label">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                Your message
                            </div>
                            <p class="req-message"><%= req.request_message %></p>
                        </div>
                        <% } %>

                    </div>
                </div>
                <% }) %>

            </div>

        <% } else { %>

            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="empty-title">No requests sent yet</div>
                <p class="empty-sub">You haven't sent any advisor requests. Browse faculty members and find the right guide for your project.</p>
                <a href="/student/find/advisors" class="btn-primary">Find an Advisor →</a>
            </div>

        <% } %>

    </div>

    <footer class="footer">
        <div class="footer-inner">
            <span class="footer-logo">Team<span>Match</span></span>
            <span class="footer-copy">University Project Collaboration Platform</span>
        </div>
    </footer>

</body>
</html>
