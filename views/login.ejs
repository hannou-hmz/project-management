<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || "ProjectHub Login" %></title>

  <link rel="stylesheet" href="/styling/login.css">
  <link rel="icon" href="/img/fav.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
</head>

<body>

<div class="page-split">

  <!-- Left Panel — Form -->
  <div class="left-panel">
    <div class="left-top">
      <a href="/" class="brand">Team<span>Match</span></a>
      <button class="back-btn" onclick="goHome()">← Home</button>
    </div>

    <div class="form-wrap">
      <div class="form-card">

        <div class="form-top">
          <h2 class="form-title">Welcome back</h2>
          <p class="form-sub">Sign in to your account to continue</p>
        </div>

        <!-- Role Selector -->
        <div class="field-group">
          <label class="field-label">I am a</label>
          <div class="role-toggle">
            <div class="role active" data-role="3">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Student
            </div>
            <div class="role" data-role="2">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              Instructor
            </div>
          </div>
        </div>

        <form method="POST" action="/login">

          <input type="hidden" name="role" id="role" value="3">

          <div class="field-group">
            <label class="field-label">Email Address</label>
            <input class="field-input" type="email" name="email" placeholder="you@university.edu" required>
          </div>

          <div class="field-group">
            <label class="field-label">Password</label>
            <input class="field-input" type="password" name="password" placeholder="Enter your password" required>
          </div>

          <button type="submit" class="signin-btn">Sign In</button>

        </form>

        <p class="signup-text">
          Don't have an account? <a href="/signup" class="signup-link">Sign up</a>
        </p>

        <div class="admin-box">
          <div class="admin-box-left">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>Are you an admin?</span>
          </div>
          <button class="admin-btn" id="admin-click" type="button">Admin Login</button>
        </div>

      </div>
    </div>
  </div>

  <!-- Right Panel — Branding -->
  <div class="right-panel">
    <div class="right-content">
      <div class="right-eyebrow">University Project Hub</div>
      <h1 class="right-title">Where great<br>teams <em>begin</em></h1>
      <p class="right-sub">Connect with students, discover projects, and build something meaningful — together.</p>

      <div class="feature-list">
        <div class="feature-item">
          <div class="feature-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <div>
            <div class="feature-title">Browse open projects</div>
            <div class="feature-desc">Filter by department, skills, and team size</div>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <div class="feature-title">Find your team</div>
            <div class="feature-desc">Match with students who complement your skills</div>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <div class="feature-title">Connect with advisors</div>
            <div class="feature-desc">Get guidance from faculty across all departments</div>
          </div>
        </div>
      </div>
    </div>

    <div class="right-orb"></div>
  </div>

</div>

<script>
    const roles = document.querySelectorAll('.role'); 
    const input = document.getElementById('role');    

    roles.forEach(div => {
      div.addEventListener("click", () => {

        const role = div.dataset.role;
        input.value = role;

        roles.forEach(r => r.classList.remove('active'));
        div.classList.add('active');
      });
    });

    function goHome(){
      window.location.href = '/';
    }

    const admin = document.getElementById('admin-click');
    admin.addEventListener("click", (event) => {
      event.preventDefault();
      window.location.href = '/admin/dashboard';
    });
</script>

</body>
</html>
