<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title || "ProjectHub Login" %></title>

  <link rel="stylesheet" href="/styling/login.css">
  <link rel="icon" href="/img/fav.png">
</head>

<body>

  <div class="container">

    <h1 class="title">ProjectHub</h1>

    <button class="back-btn" onclick="goHome()">🏠 Back to Home</button>

    <div class="card">

      <h2>Welcome Back</h2>

      <p class="subtitle">Sign in to your account to continue</p>

      <p>I am a</p>

      <div class="role-toggle">
        <div class="role active" data-role="3">Student</div>
        <div class="role" data-role="2">Instructor</div>
      </div>

      <form method="POST" action="/login">

        <input type="hidden" name="role" id="role" value="3">

        <label>Email Address</label>
        <input type="email" name="email" placeholder="you@example.com" required>

        <label>Password</label>
        <input type="password" name="password" placeholder="Enter your password" required>

        <button type="submit" class="signin-btn">Sign In</button>

      </form>

      <p class="signup-text">
        Don't have an account? <a href="/signup">Sign up</a>
      </p>

      <div class="admin-box">
        <span>🔐 Are you an admin?</span>
        <button class="admin-btn" id="admin-click" type="button">Admin Login</button>
      </div>

    </div>
  </div>

  <script>
    const roles = document.querySelectorAll('.role'); 
    const input = document.getElementById('role');    

    roles.forEach(div => {
      div.addEventListener("click", () => {

        const role = div.dataset.role;
        input.value = role;

        roles.forEach(r => r.classList.remove('active'));
        div.classList.add('active');
      });
    });

    function goHome(){
      window.location.href = '/';
    }

    const admin = document.getElementById('admin-click');
    admin.addEventListener("click", (event) => {
      event.preventDefault();
      window.location.href = '/admin/dashboard';
    });
  </script>

</body>
</html>