<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title || "ProjectHub Login" %></title>

<link rel="stylesheet" href="/auth-styling/login.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>

<body>

<div class="page">

<!-- Brand -->
<a href="/" class="brand">Team<span>Match</span></a>

<!-- Heading -->
<div class="page-top">
<h1 class="page-title">Welcome back</h1>
<p class="page-sub">Sign in to your account to continue</p>
</div>

<!-- Form card -->
<div class="form-card">

<!-- Role Selector -->
<div class="field-group">
    <label class="field-label">I am a</label>
    <div class="role-toggle">
        <div class="role active" data-role="3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Student
        </div>
        <div class="role" data-role="2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            Instructor
        </div>
    </div>
</div>

<form method="POST" action="/login" id="loginForm" novalidate>

    <input type="hidden" name="role" id="role" value="3">

    <div class="field-group">
        <label class="field-label">Email Address</label>
        <div class="input-wrap">
            <svg class="input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input class="field-input" type="email" id="emailInput" name="email" placeholder="you@university.edu">
        </div>
        <span class="field-error" id="emailError"></span>
    </div>

    <div class="field-group">
        <label class="field-label">Password</label>
        <div class="input-wrap">
            <svg class="input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input class="field-input" type="password" id="passwordInput" name="password" placeholder="Enter your password">
        </div>
        <span class="field-error" id="passwordError"></span>
    </div>

    <a href="#" class="forgot-link">Forgot password?</a>

    <button type="submit" class="signin-btn">Sign In</button>

</form>

<p class="signup-text">
    Don't have an account? <a href="/signup" class="signup-link">Sign up →</a>
</p>

<!-- Admin box -->
<div class="admin-box">
    <div class="admin-box-left">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span>Are you an admin?</span>
    </div>
    <button class="admin-btn" id="admin-click" type="button">Admin Login</button>
</div>

</div>

<p class="back-link"><button class="back-btn" onclick="goHome()">← Back to home</button></p>

</div>

<script>
const roles = document.querySelectorAll('.role'); 
const input = document.getElementById('role');    

roles.forEach(div => {
    div.addEventListener("click", () => {
        const role = div.dataset.role;
        input.value = role;
        roles.forEach(r => r.classList.remove('active'));
        div.classList.add('active');
    });
});

function goHome(){
    window.location.href = '/';
}

const admin = document.getElementById('admin-click');
admin.addEventListener("click", (event) => {
    event.preventDefault();
    window.location.href = '/admin/dashboard';
});

// ── Validation ──────────────────────────────────────
const form          = document.getElementById('loginForm');
const emailInput    = document.getElementById('emailInput');
const passwordInput = document.getElementById('passwordInput');
const emailError    = document.getElementById('emailError');
const passwordError = document.getElementById('passwordError');

function showError(el, input, msg) {
    el.textContent = msg;
    el.style.display = 'flex';
    input.classList.add('input-invalid');
}

function clearError(el, input) {
    el.textContent = '';
    el.style.display = 'none';
    input.classList.remove('input-invalid');
}

emailInput.addEventListener('input', () => clearError(emailError, emailInput));
passwordInput.addEventListener('input', () => clearError(passwordError, passwordInput));

form.addEventListener('submit', (e) => {
    let valid = true;

    const emailVal    = emailInput.value.trim();
    const passwordVal = passwordInput.value;
    const emailRegex  = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!emailVal) {
        showError(emailError, emailInput, 'Email address is required.');
        valid = false;
    } else if (!emailRegex.test(emailVal)) {
        showError(emailError, emailInput, 'Please enter a valid email address.');
        valid = false;
    } else {
        clearError(emailError, emailInput);
    }

    if (!passwordVal) {
        showError(passwordError, passwordInput, 'Password is required.');
        valid = false;
    } else if (passwordVal.length < 6) {
        showError(passwordError, passwordInput, 'Password must be at least 6 characters.');
        valid = false;
    } else {
        clearError(passwordError, passwordInput);
    }

    if (!valid) e.preventDefault();
});
</script>

</body>
</html>
