<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "Signup" %></title>

    <link rel="stylesheet" href="/auth-styling/signup.css">
    <link rel="icon" href="/img/fav.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>

<body>

<div class="page">

    <!-- Brand -->
    <a href="/" class="brand">Team<span>Match</span></a>

    <!-- Heading -->
    <div class="page-top">
        <h1 class="page-title">Create your account</h1>
        <p class="page-sub">Already have an account? <a href="/login" class="inline-link">Sign in →</a></p>
    </div>

    <!-- Form card -->
    <div class="form-card">

        <form method="POST" action="/signup">

            <!-- Role Selector -->
            <div class="field-group">
                <label class="field-label">I am a</label>
                <div class="roles">
                    <div class="role active" data-role="3">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Student
                    </div>
                    <div class="role" data-role="2">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                        Instructor
                    </div>
                </div>
                <!-- hidden input -->
                <input type="hidden" name="role" id="role" value="3">
            </div>

            <!-- Name & Email -->
            <div class="field-row">
                <div class="field-group">
                    <label class="field-label">Full Name</label>
                    <input class="field-input" type="text" name="username" placeholder="e.g. Alex Johnson" required>
                </div>
                <div class="field-group">
                    <label class="field-label">Email Address</label>
                    <input class="field-input" type="email" name="email" placeholder="you@university.edu" required>
                </div>
            </div>

            <!-- Department & Age -->
            <div class="field-row">
                <div class="field-group">
                    <label class="field-label">Department</label>
                    <select class="field-input field-select" name="department" required>
                        <option value="">Select department</option>
                        <option value="302">Computer Science</option>
                        <option value="405">Industrial Engineering</option>
                        <option value="301">Robotic Engineering</option>
                        <option value="200">Software Engineering</option>
                        <option value="101">Chemical Engineering</option>
                        <option value="111">Electrical Engineering</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Age</label>
                    <input class="field-input" type="number" name="age" placeholder="e.g. 21" required>
                </div>
            </div>

            <!-- Passwords -->
            <div class="field-row">
                <div class="field-group">
                    <label class="field-label">Password</label>
                    <input class="field-input" type="password" name="password" placeholder="Create a password" required>
                </div>
                <div class="field-group">
                    <label class="field-label">Confirm Password</label>
                    <input class="field-input" type="password" name="confirm_password" placeholder="Repeat password" required>
                </div>
            </div>

            <button class="submit-btn" type="submit">Create Account</button>

        </form>

    </div>

    <p class="back-link"><a href="/">← Back to home</a></p>

</div>

<script>
  const roles = document.querySelectorAll('.role');
  const input = document.getElementById('role');

  roles.forEach(div => {
    div.addEventListener('click', () => {
      const role = div.dataset.role;

      input.value = role;

      roles.forEach(r => r.classList.remove('active'));
      div.classList.add('active');
    });
  });
</script>

</body>
</html>
