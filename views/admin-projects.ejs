<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Projects — Admin · TeamMatch</title>
<link rel="stylesheet" href="/admin-styling/admin-projects.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ═══════════════════════════════════════
    SIDEBAR
════════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">

<div class="sb-brand">
  <div class="sb-logo">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor"/><path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/><path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
  </div>
  <div class="sb-brand-text">
    <span class="sb-name">Team<em>Match</em></span>
    <span class="sb-role">Admin Console</span>
  </div>
</div>

<nav class="sb-nav">
  <div class="sb-nav-label">Main Menu</div>

  <a href="/admin/homepage" class="sb-link">
    <span class="sb-link-icon">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
    </span>
    <span class="sb-link-label">Dashboard</span>
  </a>

  <a href="/admin/categories" class="sb-link">
    <span class="sb-link-icon">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
    </span>
    <span class="sb-link-label">Categories</span>
  </a>

  <a href="/admin/projects" class="sb-link active">
    <span class="sb-link-icon">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    </span>
    <span class="sb-link-label">Projects</span>
  </a>

  <a href="/admin/announcements" class="sb-link">
    <span class="sb-link-icon">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </span>
    <span class="sb-link-label">Announcements</span>
  </a>

  <a href="/admin/users/roles" class="sb-link">
    <span class="sb-link-icon">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </span>
    <span class="sb-link-label">Users &amp; Roles</span>
  </a>
</nav>

<div class="sb-footer">
  <div class="sb-admin-row">
    <div class="sb-avatar">A</div>
    <div class="sb-admin-info">
      <div class="sb-admin-name">Admin</div>
      <div class="sb-admin-sub">Super Admin</div>
    </div>
    <a href="/logout" class="sb-logout-btn" title="Logout">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    </a>
  </div>
</div>

</aside>

<!-- ═══════════════════════════════════════
    LAYOUT MAIN
════════════════════════════════════════ -->
<div class="layout-main">

<!-- ── Topbar ── -->
<header class="topbar">
  <div class="topbar-left">
    <button class="mobile-toggle" onclick="toggleSidebar()" aria-label="Toggle sidebar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="topbar-breadcrumb">
      <span class="tb-root">TeamMatch</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span class="tb-current">Projects</span>
    </div>
  </div>
  <div class="topbar-right">
    <% if (projects && projects.length > 0) { %>
    <div class="topbar-count">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <strong><%= projects.length %></strong>&nbsp;project<%= projects.length !== 1 ? 's' : '' %>
    </div>
    <% } %>
  </div>
</header>

<!-- ── Page Content ── -->
<main class="page-content">

  <div class="page-heading">
    <div>
      <h1 class="page-title">Projects</h1>
      <p class="page-subtitle">View and moderate all student-created projects across every department.</p>
    </div>
  </div>

  <!-- Panel -->
  <div class="panel">

    <div class="panel-header">
      <div class="panel-header-left">
        <div class="panel-title">All Projects</div>
        <div class="panel-sub">
          <% if (projects && projects.length > 0) { %>
            <%= projects.length %> project<%= projects.length !== 1 ? 's' : '' %> on the platform
          <% } else { %>
            No projects yet
          <% } %>
        </div>
      </div>
      <% if (projects && projects.length > 0) { %>
      <div class="search-wrap">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="search-input" id="searchInput" placeholder="Search title, category, or skills…">
      </div>
      <% } %>
    </div>

    <div class="panel-body">

      <% if (projects && projects.length > 0) { %>

        <div class="table-wrap">
          <table class="data-table" id="projectsTable">
            <thead>
              <tr>
                <th>Project Title</th>
                <th>Category</th>
                <th>Budget</th>
                <th>Skills</th>
                <th>Created</th>
                <th class="th-right">Action</th>
              </tr>
            </thead>
            <tbody>
              <% projects.forEach(project => { %>
              <tr class="project-row"
                  data-title="<%= project.project_title %>"
                  data-category="<%= project.category_name %>"
                  data-skills="<%= project.required_skills %>">

                <td>
                  <div class="project-title-cell">
                    <span class="project-title-text"><%= project.project_title %></span>
                    <span class="project-desc-text"><%= project.project_description ? project.project_description.substring(0, 80) + (project.project_description.length > 80 ? '…' : '') : '' %></span>
                  </div>
                </td>

                <td>
                  <span class="cat-badge"><%= project.category_name %></span>
                </td>

                <td class="td-budget">
                  $<%= project.budget ? Number(project.budget).toLocaleString() : '0' %>
                </td>

                <td>
                  <div class="skills-cell">
                    <% if (project.required_skills) { %>
                      <% project.required_skills.split(',').slice(0,2).forEach(skill => { %>
                        <span class="skill-tag"><%= skill.trim() %></span>
                      <% }) %>
                      <% if (project.required_skills.split(',').length > 2) { %>
                        <span class="skill-more">+<%= project.required_skills.split(',').length - 2 %></span>
                      <% } %>
                    <% } else { %>
                      <span class="no-skills">—</span>
                    <% } %>
                  </div>
                </td>

                <td class="td-date">
                  <%= new Date(project.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </td>

                <td class="td-action-cell">
                  <input type="hidden" name="projectId">
                  <button class="btn-delete"
                          data-href="/admin/projects/<%= project.project_id %>/delete"
                          data-title="<%= project.project_title %>"
                          onclick="openDeleteModal(this)">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    Delete
                  </button>
                </td>

              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="empty-search" id="emptySearch" style="display:none;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          No projects match your search.
        </div>

      <% } else { %>

        <div class="empty-state">
          <div class="empty-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div class="empty-title">No projects yet</div>
          <p class="empty-sub">No projects have been created on the platform yet.</p>
        </div>

      <% } %>

    </div>
  </div>

</main>
</div>


<!-- ═══════════════════════════════════════
    DELETE MODAL
════════════════════════════════════════ -->
<div class="modal-backdrop" id="modalBackdrop" onclick="closeDeleteModal()">
<div class="modal modal-delete" id="deleteModal" onclick="event.stopPropagation()">

  <div class="delete-icon-wrap">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
  </div>

  <h3 class="modal-title">Delete Project</h3>
  <p class="delete-body">
    Are you sure you want to permanently delete
    <strong id="modalProjectName"></strong>?
    All applications linked to this project will also be removed.
  </p>

  <div class="modal-footer modal-footer-center">
    <button class="btn btn-ghost" onclick="closeDeleteModal()">Cancel</button>
    <a class="btn btn-danger" id="modalConfirmBtn" href="#">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      Delete Project
    </a>
  </div>

</div>
</div>


<script>
// ===== DELETE MODAL =====
function openDeleteModal(btn) {
  document.getElementById('modalProjectName').textContent = btn.dataset.title;
  document.getElementById('modalConfirmBtn').setAttribute('href', btn.dataset.href);
  document.getElementById('modalBackdrop').classList.add('visible');
  document.body.style.overflow = 'hidden';
}
function closeDeleteModal() {
  document.getElementById('modalBackdrop').classList.remove('visible');
  document.body.style.overflow = '';
}

// ===== SEARCH =====
const searchInput = document.getElementById('searchInput');
const rows = document.querySelectorAll('.project-row');
const emptySearch = document.getElementById('emptySearch');

if (searchInput) {
  searchInput.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase();
    let visible = 0;
    rows.forEach(row => {
      const title    = (row.dataset.title    || '').toLowerCase();
      const category = (row.dataset.category || '').toLowerCase();
      const skills   = (row.dataset.skills   || '').toLowerCase();
      const match = !q || title.includes(q) || category.includes(q) || skills.includes(q);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (emptySearch) emptySearch.style.display = visible === 0 ? 'flex' : 'none';
  });
}

// Mobile sidebar
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('visible');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('visible');
}

// Close on Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeDeleteModal();
});

// Stagger rows on load
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.project-row').forEach((row, i) => {
    row.style.opacity = '0';
    row.style.transform = 'translateY(8px)';
    setTimeout(() => {
      row.style.transition = 'opacity .35s ease, transform .35s ease';
      row.style.opacity = '1';
      row.style.transform = 'translateY(0)';
    }, 60 + i * 40);
  });
});
</script>

</body>
</html>
