<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Advisor Dashboard</title>
<link rel="stylesheet" href="/advisor-styling/advisor-homepage.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
</head>
<body>

<%
    const isAvailable = !!(advisor.is_available || advisor.available);
%>

<!-- ===== SIDEBAR ===== -->
<aside class="sidebar">

    <!-- Brand -->
    <div class="sidebar-brand">
        <a href="/advisor/dashboard" class="brand-link">Team<span>Match</span></a>
        <div class="brand-role">Advisor Portal</div>
    </div>

    <!-- Advisor identity card -->
    <div id="profile" class="sidebar-profile">
        <div  class="sp-avatar">
            <%= advisor.full_name ? advisor.full_name.split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase() : 'AD' %>
        </div>
        <div class="sp-info">
            <div class="sp-name"><%= advisor.full_name || 'Advisor' %></div>
            <% if (advisor.academic_title) { %>
            <div class="sp-title"><%= advisor.academic_title %></div>
            <% } %>
        </div>
        <!-- Availability indicator -->
        <div class="sp-avail-dot <%= isAvailable ? 'dot-on' : 'dot-off' %>"
                title="<%= isAvailable ? 'Available' : 'Unavailable' %>"></div>
    </div>

    <!-- Availability strip -->
    <div class="sidebar-avail <%= isAvailable ? 'avail-on' : 'avail-off' %>">
        <div class="sa-label"><%= isAvailable ? 'Available for advising' : 'Not accepting requests' %></div>
        <a href="/advisor/profile" class="sa-link">Change →</a>
    </div>

    <div class="sidebar-divider"></div>

    <!-- Navigation -->
    <div class="sidebar-section-label">Navigation</div>
    <nav class="sidebar-nav">
        <a href="/advisor/dashboard" class="sidebar-link active">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
        </a>
        <a href="/advisor/projects" class="sidebar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/></svg>
            My Projects
        </a>
        <a href="/advisor/requests" class="sidebar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Student Requests
        </a>
        <a href="/advisor/profile" class="sidebar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            My Profile
        </a>
    </nav>

    <!-- Logout -->
    <div class="sidebar-footer">
        <a href="/logout" class="sidebar-logout">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Logout
        </a>
    </div>

</aside>

<!-- ===== MAIN ===== -->
<main class="main">

    <!-- Topbar -->
    <div class="topbar">
        <div class="topbar-left">
            <div class="topbar-title">Dashboard</div>
            <div class="topbar-sub">Overview of your advising activity</div>
        </div>
        <div class="topbar-right">
            <div class="topbar-date" id="topbarDate"></div>
            <div class="topbar-avail-pill <%= isAvailable ? 'pill-on' : 'pill-off' %>">
                <div class="pill-dot"></div>
                <%= isAvailable ? 'Available' : 'Unavailable' %>
            </div>
        </div>
    </div>

    <!-- Page content -->
    <div class="content">

        <!-- Welcome banner -->
        <div class="welcome-banner">
            <div class="wb-inner">
                <div class="wb-eyebrow">Good to see you</div>
                <h1 class="wb-title"><%= advisor.full_name || 'Advisor' %></h1>
                <% if (advisor.department_name) { %>
                <div class="wb-meta">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    <%= advisor.department_name %>
                    <% if (advisor.email) { %>
                    <span class="wb-sep">·</span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <%= advisor.email %>
                    <% } %>
                </div>
                <% } %>
            </div>
            <div class="wb-orb"></div>
        </div>

        <!-- Section cards -->
        <div class="section-label">Quick Access</div>

        <div class="section-cards">

            <a href="/advisor/projects" class="section-card sc-featured">
                <div class="sc-icon sc-icon-navy">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/></svg>
                </div>
                <div class="sc-body">
                    <div class="sc-title">My Projects</div>
                    <div class="sc-desc">View and manage all student projects currently under your advisory</div>
                </div>
                <div class="sc-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
            </a>

            <a href="/advisor/requests" class="section-card">
                <div class="sc-icon sc-icon-green">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div class="sc-body">
                    <div class="sc-title">Student Requests</div>
                    <div class="sc-desc">Review, accept, or decline advising requests sent by students</div>
                </div>
                <div class="sc-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
            </a>

            <a href="/advisor/profile" class="section-card">
                <div class="sc-icon sc-icon-amber">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="sc-body">
                    <div class="sc-title">My Profile</div>
                    <div class="sc-desc">Update your bio, expertise, research interests, and availability status</div>
                </div>
                <div class="sc-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
            </a>

        </div>

    </div>
</main>

<script>
    const el = document.getElementById('topbarDate');
    if (el) {
        const now = new Date();
        el.textContent = now.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
    }

    
        const getProfile = document.getElementById('profile').onclick = function profile(){
                window.location.href = '/advisor/profile'
            }
    
</script>

</body>
</html>
