<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Advisor Dashboard — TeamMatch</title>
<link rel="stylesheet" href="/advisor-styling/advisor-homepage.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<%
const isAvailable = !!(advisor.is_available || advisor.is_available);
%>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ═══════════════════════════════════════
     SIDEBAR
════════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">

  <!-- Brand -->
  <div class="sb-brand">
    <div class="sb-logo">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor"/><path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/><path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
    </div>
    <div class="sb-brand-text">
      <a href="/advisor/dashboard" class="sb-name">Team<em>Match</em></a>
      <span class="sb-role">Advisor Portal</span>
    </div>
  </div>

  <!-- Advisor identity card -->
  <div id="profile" class="sb-profile" onclick="window.location.href='/advisor/profile'" title="View profile">
    <div class="sp-avatar">
      <%= advisor.full_name ? advisor.full_name.split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase() : 'AD' %>
    </div>
    <div class="sp-info">
      <div class="sp-name"><%= advisor.full_name || 'Advisor' %></div>
      <% if (advisor.academic_title) { %>
      <div class="sp-title"><%= advisor.academic_title %></div>
      <% } %>
    </div>
    <div class="sp-avail-dot <%= isAvailable  ? 'dot-on' : 'dot-off' %>"
         title="<%= isAvailable  ? 'Available' : 'Unavailable' %>"></div>
  </div>

  <!-- Availability strip -->
  <div class="sb-avail-strip <%= isAvailable  ? 'avail-on' : 'avail-off' %>">
    <span class="sa-label"><%= isAvailable  ? 'Available for advising' : 'Not accepting requests' %></span>
    <a href="/advisor/profile" class="sa-link">Change →</a>
  </div>

  <div class="sb-divider"></div>

  <!-- Nav -->
  <nav class="sb-nav">
    <div class="sb-nav-label">Navigation</div>

    <a href="/advisor/dashboard" class="sb-link active">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
      </span>
      <span class="sb-link-label">Dashboard</span>
    </a>

    <a href="/advisor/projects" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/></svg>
      </span>
      <span class="sb-link-label">My Projects</span>
    </a>

    <a href="/advisor/requests" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </span>
      <span class="sb-link-label">New Requests</span>
      <% if (pending > 0) { %>
      <span class="sb-badge"><%= pending %></span>
      <% } %>
    </a>

    <a href="/advisor/profile" class="sb-link">
      <span class="sb-link-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </span>
      <span class="sb-link-label">My Profile</span>
    </a>
  </nav>

  <!-- Footer -->
  <div class="sb-footer">
    <a href="/logout" class="sb-logout-btn">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Logout
    </a>
  </div>

</aside>

<!-- ═══════════════════════════════════════
     LAYOUT MAIN
════════════════════════════════════════ -->
<div class="layout-main">

  <!-- ── Topbar ── -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="mobile-toggle" onclick="toggleSidebar()" aria-label="Toggle sidebar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-breadcrumb">
        <span class="tb-root">TeamMatch</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="tb-current">Dashboard</span>
      </div>
    </div>
    <div class="topbar-right">
      <div class="topbar-date" id="topbarDate"></div>
      <div class="tb-sep"></div>
      <div class="topbar-avail-pill <%= isAvailable ? 'pill-on' : 'pill-off' %>">
        <span class="pill-dot"></span>
        <%= isAvailable? 'Available' : 'Unavailable' %>
      </div>
    </div>
  </header>

  <!-- ── Page content ── -->
  <main class="page-content">

    <!-- Welcome banner -->
    <div class="welcome-banner">
      <div class="wb-inner">
        <div class="wb-eyebrow">Good to see you</div>
        <h1 class="wb-title"><%= advisor.full_name || 'Advisor' %></h1>
        <% if (advisor.department_name) { %>
        <div class="wb-meta">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <%= advisor.department_name %>
          <% if (advisor.email) { %>
          <span class="wb-sep">·</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <%= advisor.email %>
          <% } %>
        </div>
        <% } %>
      </div>
      <div class="wb-orb"></div>
    </div>

    <!-- ── Request stats ── -->
    <div class="section-eyebrow">Request Overview</div>

    <div class="stats-grid">

      <div class="stat-card sc-green">
        <div class="stat-top">
          <div class="stat-icon-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span class="stat-live stat-live-green">● Live</span>
        </div>
        <div class="stat-num"><%= accepted %></div>
        <div class="stat-label">Accepted</div>
        <div class="stat-hint">Students currently advising</div>
      </div>

      <div class="stat-card sc-amber">
        <div class="stat-top">
          <div class="stat-icon-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <span class="stat-live stat-live-amber">● Live</span>
        </div>
        <div class="stat-num"><%= total_pending %></div>
        <div class="stat-label">Pending</div>
        <div class="stat-hint">Awaiting your response</div>
      </div>

      <div class="stat-card sc-coral">
        <div class="stat-top">
          <div class="stat-icon-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </div>
          <span class="stat-live stat-live-coral">● Live</span>
        </div>
        <div class="stat-num"><%= rejected %></div>
        <div class="stat-label">Rejected</div>
        <div class="stat-hint">Requests declined</div>
      </div>

    </div>

    <!-- ── Quick access ── -->
    <div class="section-eyebrow">Quick Access</div>

    <div class="quick-grid">

      <a href="/advisor/projects" class="quick-card qc-featured">
        <div class="qc-icon qc-blue">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/></svg>
        </div>
        <div class="qc-body">
          <div class="qc-title">My Projects</div>
          <div class="qc-desc">View and manage all student projects currently under your advisory</div>
        </div>
        <div class="qc-arrow">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </div>
      </a>

      <a href="/advisor/requests" class="quick-card">
        <div class="qc-icon qc-green">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div class="qc-body">
          <div class="qc-title">
            New Requests
            <% if (pending > 0) { %>
            <span class="qc-badge"><%= pending %> pending</span>
            <% } %>
          </div>
          <div class="qc-desc">Review, accept, or decline advising requests sent by students</div>
        </div>
        <div class="qc-arrow">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </div>
      </a>

      <a href="/advisor/profile" class="quick-card">
        <div class="qc-icon qc-amber">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="qc-body">
          <div class="qc-title">My Profile</div>
          <div class="qc-desc">Update your bio, expertise, research interests, and availability status</div>
        </div>
        <div class="qc-arrow">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </div>
      </a>

    </div>

  </main>
</div>

<script>
  const el = document.getElementById('topbarDate');
  if (el) {
    const now = new Date();
    el.textContent = now.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  }

  const getProfile = document.getElementById('profile').onclick = function profile(){
    window.location.href = '/advisor/profile';
  }

  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebarOverlay').classList.toggle('visible');
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('visible');
  }

  // Stagger stat cards
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.stat-card').forEach((card, i) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(14px)';
      setTimeout(() => {
        card.style.transition = 'opacity .4s ease, transform .4s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
      }, 100 + i * 70);
    });
    document.querySelectorAll('.quick-card').forEach((card, i) => {
      card.style.opacity = '0';
      card.style.transform = 'translateX(-8px)';
      setTimeout(() => {
        card.style.transition = 'opacity .4s ease, transform .4s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateX(0)';
      }, 320 + i * 60);
    });
  });
</script>

</body>
</html>
