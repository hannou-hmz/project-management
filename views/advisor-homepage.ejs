<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Advisor Dashboard</title>
    <link rel="stylesheet" href="/styling/advisor-homepage.css">
</head>
<body>

    <!-- Navbar -->
    <div class="navbar">
        <h2>Advisor Panel</h2>
        <div class="nav-links">
            <a href="/logout">Logout</a>
        </div>
    </div>

    <div class="container">

        <!-- Sidebar -->
        <div class="sidebar">
            <a href="/advisor/dashboard">Dashboard</a>
            <a href="/advisor/requests">Requests</a>
            <a href="/advisor/projects">My Projects</a>
            <a href="/advisor/profile">Profile Settings</a>
        </div>

        <!-- Main Content -->
        <div class="content">

            <div class="card">
                <h3>Welcome, <%= advisor.full_name %> 👋</h3>
                <p>Manage your advising requests and projects here.</p>
            </div>

             <div class="card">
                <h3>Pending Requests</h3>
                <p>You have <strong><%= pending.pending_requests | 0 %></strong> pending requests.</p>
                <a href="/advisor/requests" class="btn">View Requests</a>
            </div>

        
         

        </div>

    </div>

</body>
</html>