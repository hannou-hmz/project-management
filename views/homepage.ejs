<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TeamMatch — University Project Hub</title>
<link rel="stylesheet" href="/styling/homepage.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;1,500;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
</head>
<body>

<!-- ====== NAVBAR ====== -->
<nav class="navbar">
    <a href="/" class="nav-logo">Team<span>Match</span></a>

    <ul class="nav-links">
        <li><a href="/" class="nav-link active">Home</a></li>
        <li><a href="/projects" class="nav-link">Projects</a></li>
        <li><a href="/find/advisor" class="nav-link">Find Advisor</a></li>
    </ul>

    <!-- Smart auth: swap based on session -->


    <!-- Mobile menu toggle -->
    <button class="mobile-menu-btn" id="menuToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
    </button>
</nav>

<!-- Mobile Drawer -->
<div class="mobile-drawer" id="mobileDrawer">
    <a href="/" class="drawer-link">Home</a>
    <a href="/projects" class="drawer-link">Projects</a>
    <a href="/find/advisor" class="drawer-link">Find Advisor</a>

   
</div>


<!-- ====== HERO ====== -->
<section class="hero">
    <div class="hero-inner">
        <div class="hero-content">
            <div class="hero-eyebrow">University Project Collaboration</div>
            <h1 class="hero-title">
                Find your team.<br>
                Build something <em>great</em>.
            </h1>
            <p class="hero-sub">
                TeamMatch connects university students with the right collaborators,
                advisors, and projects — all in one place.
            </p>
            <div class="hero-btns">
                <a href="/projects" class="btn-primary">Browse Projects</a>
                <a href="/signup" class="btn-outline-light">Get Started Free</a>
            </div>
        </div>

        <!-- Floating project preview card -->
        <div class="hero-card">
            <div class="hc-label">Trending right now</div>
            <div class="hc-item">
                <div class="hc-dot amber"></div>
                <div class="hc-text">
                    <div class="hc-name">AI Study Assistant</div>
                    <div class="hc-meta">Computer Science · 2 spots left</div>
                </div>
            </div>
            <div class="hc-item">
                <div class="hc-dot blue"></div>
                <div class="hc-text">
                    <div class="hc-name">Campus Sustainability App</div>
                    <div class="hc-meta">Engineering · 3 spots left</div>
                </div>
            </div>
            <div class="hc-item">
                <div class="hc-dot green"></div>
                <div class="hc-text">
                    <div class="hc-name">Smart Scheduling System</div>
                    <div class="hc-meta">Software Engineering · 1 spot left</div>
                </div>
            </div>
            <a href="/projects" class="hc-cta">View all projects →</a>
        </div>
    </div>

    <div class="hero-orb-1"></div>
    <div class="hero-orb-2"></div>
</section>


<!-- ====== STATS BAR ====== -->



<!-- ====== HOW IT WORKS ====== -->
<section class="how-section">
    <div class="section-inner">
        <div class="section-header">
            <div class="section-eyebrow">How it works</div>
            <h2 class="section-title">From signup to collaboration<br>in three steps</h2>
        </div>

        <div class="steps-grid">
            <div class="step-card">
                <div class="step-num">01</div>
                <div class="step-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <h3 class="step-title">Create your profile</h3>
                <p class="step-desc">Sign up, list your skills, and tell your future teammates what you bring to the table.</p>
            </div>

            <div class="step-connector">
                <svg width="32" height="12" viewBox="0 0 32 12" fill="none"><path d="M0 6h28M22 1l6 5-6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>

            <div class="step-card">
                <div class="step-num">02</div>
                <div class="step-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </div>
                <h3 class="step-title">Browse projects</h3>
                <p class="step-desc">Explore open projects across every department. Filter by skill, team size, or deadline.</p>
            </div>

            <div class="step-connector">
                <svg width="32" height="12" viewBox="0 0 32 12" fill="none"><path d="M0 6h28M22 1l6 5-6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>

            <div class="step-card">
                <div class="step-num">03</div>
                <div class="step-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <h3 class="step-title">Join a team</h3>
                <p class="step-desc">Apply to projects, get accepted, and start collaborating with your new team right away.</p>
            </div>
        </div>
    </div>
</section>


<!-- ====== FEATURED PROJECTS ====== -->
<section class="projects-section">
    <div class="section-inner">
        <div class="section-header projects-header">
            <div>
                <div class="section-eyebrow">Open projects</div>
                <h2 class="section-title">Find your next collaboration</h2>
            </div>
            <a href="/projects" class="btn-secondary">View all →</a>
        </div>

        <div class="projects-grid">
            <% if (projects && projects.length > 0) { %>
                <% projects.forEach(project => { %>
                    <div class="project-card">
                        <div class="pc-top">
                            <div class="pc-header">
                                <h3 class="pc-title"><%= project.title %></h3>
                                <span class="pc-status open">Open</span>
                            </div>
                            <div class="pc-dept"><%= project.department_name || project.department %></div>
                            <p class="pc-desc"><%= project.description ? project.description.substring(0, 110) + (project.description.length > 110 ? '...' : '') : '' %></p>
                        </div>
                        <div class="pc-bottom">
                            <div class="pc-tags">
                                <% if (project.skills) { %>
                                    <% project.skills.split(',').slice(0, 3).forEach(skill => { %>
                                        <span class="pc-tag"><%= skill.trim() %></span>
                                    <% }) %>
                                <% } %>
                            </div>
                            <div class="pc-footer">
                                <span class="pc-slots">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                    <%= project.open_slots || project.max_members %> spots left
                                </span>
                                <a href="/projects/<%= project.id %>" class="pc-link">Apply →</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <!-- Fallback placeholder cards if no projects passed -->
                <div class="project-card">
                    <div class="pc-top">
                        <div class="pc-header">
                            <h3 class="pc-title">AI-Powered Study Assistant</h3>
                            <span class="pc-status open">Open</span>
                        </div>
                        <div class="pc-dept">Computer Science</div>
                        <p class="pc-desc">Building an LLM-based tool that helps students organize and quiz themselves on lecture material automatically.</p>
                    </div>
                    <div class="pc-bottom">
                        <div class="pc-tags">
                            <span class="pc-tag">Python</span>
                            <span class="pc-tag">NLP</span>
                            <span class="pc-tag">React</span>
                        </div>
                        <div class="pc-footer">
                            <span class="pc-slots">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                2 spots left
                            </span>
                            <a href="/signup" class="pc-link">Apply →</a>
                        </div>
                    </div>
                </div>
                <div class="project-card">
                    <div class="pc-top">
                        <div class="pc-header">
                            <h3 class="pc-title">Campus Sustainability Tracker</h3>
                            <span class="pc-status open">Open</span>
                        </div>
                        <div class="pc-dept">Environmental Engineering</div>
                        <p class="pc-desc">A mobile app to track and gamify carbon footprint reduction across campus for students and faculty members.</p>
                    </div>
                    <div class="pc-bottom">
                        <div class="pc-tags">
                            <span class="pc-tag">Flutter</span>
                            <span class="pc-tag">UI/UX</span>
                            <span class="pc-tag">Firebase</span>
                        </div>
                        <div class="pc-footer">
                            <span class="pc-slots">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                3 spots left
                            </span>
                            <a href="/signup" class="pc-link">Apply →</a>
                        </div>
                    </div>
                </div>
                <div class="project-card">
                    <div class="pc-top">
                        <div class="pc-header">
                            <h3 class="pc-title">Smart Campus Scheduling</h3>
                            <span class="pc-status open">Open</span>
                        </div>
                        <div class="pc-dept">Software Engineering</div>
                        <p class="pc-desc">Redesigning the university room booking system with an intelligent conflict-resolution engine and real-time updates.</p>
                    </div>
                    <div class="pc-bottom">
                        <div class="pc-tags">
                            <span class="pc-tag">Node.js</span>
                            <span class="pc-tag">PostgreSQL</span>
                            <span class="pc-tag">React</span>
                        </div>
                        <div class="pc-footer">
                            <span class="pc-slots">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                1 spot left
                            </span>
                            <a href="/signup" class="pc-link">Apply →</a>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</section>


<!-- ====== ADVISOR CTA BANNER ====== -->
<section class="advisor-section">
    <div class="advisor-inner">
        <div class="advisor-content">
            <div class="advisor-eyebrow">Faculty Advisors</div>
            <h2 class="advisor-title">Need expert guidance<br>for your project?</h2>
            <p class="advisor-sub">Browse faculty advisors across all departments and send a collaboration request directly from the platform.</p>
            <a href="/find/advisor" class="btn-amber">Find an Advisor →</a>
        </div>
        <div class="advisor-illustration">
            <div class="adv-card adv-card-1">
                <div class="adv-avatar">DR</div>
                <div class="adv-info">
                    <div class="adv-name">Dr. Rania Khalil</div>
                    <div class="adv-dept">Computer Science</div>
                </div>
                <div class="adv-badge">Available</div>
            </div>
            <div class="adv-card adv-card-2">
                <div class="adv-avatar">PM</div>
                <div class="adv-info">
                    <div class="adv-name">Prof. Mehmet Arslan</div>
                    <div class="adv-dept">Robotics Engineering</div>
                </div>
                <div class="adv-badge">Available</div>
            </div>
        </div>
    </div>
</section>


<!-- ====== FOOTER ====== -->
<footer class="footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <a href="/" class="footer-logo">Team<span>Match</span></a>
            <p class="footer-tagline">University Project Collaboration Platform</p>
        </div>

        <div class="footer-links">
            <div class="footer-col">
                <div class="footer-col-title">Platform</div>
                <a href="/projects" class="footer-link">Browse Projects</a>
                <a href="/find/advisor" class="footer-link">Find Advisor</a>
                <a href="/signup" class="footer-link">Get Started</a>
            </div>
            <div class="footer-col">
                <div class="footer-col-title">Account</div>
                <a href="/login" class="footer-link">Login</a>
                <a href="/signup" class="footer-link">Sign Up</a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <span>© <%= new Date().getFullYear() %> TeamMatch. All rights reserved.</span>
    </div>
</footer>


<script>
    // Mobile menu toggle
    const menuToggle = document.getElementById('menuToggle');
    const mobileDrawer = document.getElementById('mobileDrawer');

    menuToggle.addEventListener('click', () => {
        mobileDrawer.classList.toggle('open');
        menuToggle.classList.toggle('active');
    });

    // Close drawer on outside click
    document.addEventListener('click', (e) => {
        if (!menuToggle.contains(e.target) && !mobileDrawer.contains(e.target)) {
            mobileDrawer.classList.remove('open');
            menuToggle.classList.remove('active');
        }
    });
</script>

</body>
</html>
