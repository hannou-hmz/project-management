<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title || "404 - Page Not Found" %></title>
    <link rel="stylesheet" href="/styling/404.css">
</head>
<body>

<div class="container">
    <h1><%= errorCode || 404 %></h1>
    <h2>Page Not Found</h2>

    <p>
        <%= message || "The page you are looking for does not exist." %>
    </p>

    <a href="/" class="btn">Go Back Home</a>
</div>

</body>
</html>